# Managed by Ansible (seaweedfs role). Do not edit by hand.
# weed reads these via viper AutomaticEnv (prefix WEED, "." -> "_"), so they map
# to the admin flags admin.user / admin.password without exposing them in argv.
WEED_ADMIN_USER={{ seaweedfs_admin_user }}
WEED_ADMIN_PASSWORD={{ seaweedfs_admin_password }}
