{
	email {{ caddy_acme_email }}
	acme_dns cloudflare {env.CF_API_TOKEN}
	acme_ca {{ caddy_acme_ca }}
}

{% for upstream in caddy_upstreams %}
{{ upstream.hostname }} {
	reverse_proxy {{ upstream.scheme | default('http') }}://{{ upstream.backend }}{% if upstream.tls_insecure | default(false) %} {
		transport http {
			tls_insecure_skip_verify
		}
	}{% endif %}

}

{% endfor %}
