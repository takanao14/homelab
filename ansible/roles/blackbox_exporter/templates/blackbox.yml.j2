# Ansible managed
modules:
  icmp:
    prober: icmp
    timeout: 5s
    icmp:
      preferred_ip_protocol: ip4

  dns_external:
    prober: dns
    timeout: 5s
    dns:
      query_name: "google.com"
      query_type: A
      valid_rcodes:
        - NOERROR

  dns_internal:
    prober: dns
    timeout: 5s
    dns:
      query_name: "{{ blackbox_exporter_dns_internal_query }}"
      query_type: A
      valid_rcodes:
        - NOERROR
