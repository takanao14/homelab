{
  "Dhcp4": {
    "interfaces-config": {
      "interfaces": ["eth0"],
      "service-sockets-max-retries": 5,
      "service-sockets-retry-wait-time": 5000
    },
    "control-socket": {
      "socket-type": "unix",
      "socket-name": "/run/kea/kea4-ctrl-socket"
    },
    "lease-database": {
      "type": "memfile",
      "persist": true,
      "name": "/var/lib/kea/kea-leases4.csv",
      "lfc-interval": 3600
    },
    "valid-lifetime": 4000,
    "renew-timer": 1000,
    "rebind-timer": 2000,
    "expired-leases-processing": {
      "reclaim-timer-wait-time": 10,
      "hold-reclaimed-time": 3600,
      "max-reclaim-leases": 100,
      "max-reclaim-time": 250
    },
    "subnet4": [
{% for subnet in kea_subnet4 %}
      {
        "id": {{ loop.index }},
        "subnet": "{{ subnet.subnet }}",
        "pools": [
          {"pool": "{{ subnet.pool }}"}
        ],
        "option-data": [
          {"name": "routers", "data": "{{ subnet.routers }}"},
          {"name": "domain-name-servers", "data": "{{ subnet.dns_servers }}"},
          {"name": "domain-name", "data": "{{ subnet.domain_name }}"}
        ]
        {%- if subnet.reservations is defined and subnet.reservations | length > 0 -%},
        "reservations": [
          {%- for r in subnet.reservations -%}
          {
            "hw-address": "{{ r.hw_address }}",
            "ip-address": "{{ r.ip_address }}"
          }{%- if not loop.last -%},{%- endif -%}
          {%- endfor -%}
        ]
        {%- endif %}
      }{%- if not loop.last -%},{%- endif %}
{% endfor %}
    ]
  }
}
