while IFS= read -r line; do
  [[ -z "$line" || "$line" == \#* ]] && continue
  key="${line%%=*}"
  value="${line#*=}"
  value="${value#\"}"
  value="${value%\"}"
  export "$key=$value"
done < <(sops --decrypt secrets.enc.env)

sops --decrypt inventories/homelab/hosts.enc.yml > inventories/homelab/hosts.yml
