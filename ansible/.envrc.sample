# This file is a template for .envrc.
# Copy this file to .envrc and fill in your actual values.
# Then run 'direnv allow' in the ansible directory.

# --- DNS Playbook Variables (playbooks/dns.yml) ---
# Primary PowerDNS Authoritative Server address (e.g., 192.168.x.10:53)
export PRIMARY_AUTH_SERVER="<YOUR_PRIMARY_AUTH_SERVER_IP:PORT>"
# Secondary PowerDNS Authoritative Server address (e.g., 192.168.x.11:53)
export SECONDARY_AUTH_SERVER="<YOUR_SECONDARY_AUTH_SERVER_IP:PORT>"

# dnsdist local forwarder address (e.g., 192.168.x.100:53)
export DNSDIST_LOCAL_FORWARDER="<YOUR_DNSDIST_LOCAL_FORWARDER_IP:PORT>"

# dnsdist ACL
export DNSDIST_MGMT_ACL="<YOUR_DNSDIST_MANAGEMENT_ACL_IP_RANGE>" # e.g., 192.168.x.0/24
export DNSDIST_CONSOLE_ACL="<YOUR_DNSDIST_CONSOLE_ACL_IP_RANGE>" # e.g., 192.168.x.0/24

# dnsdist packet cache settings
export DNSDIST_PACKET_CACHE_SIZE="100000" # Example: 100000
export DNSDIST_PACKET_CACHE_MAX_TTL="3600" # Example: 3600 seconds

# Internal domain for dnsdist routing (e.g., sub1.example.internal., sub2.example.internal.)
export DNSDIST_INTERNAL_DOMAINS="sub1.example.internal., sub2.example.internal."
# Internal check name for dnsdist backends (e.g., ns1.example.internal.)
export DNSDIST_INTERNAL_CHECK_NAME="ns1.example.internal."

# dnsdist web UI and console authentication
export DNSDIST_WEB_PASSWORD="<YOUR_DNSDIST_WEB_PASSWORD>"
export DNSDIST_WEB_API_KEY="<YOUR_DNSDIST_WEB_API_KEY>"
export DNSDIST_CONSOLE_KEY="<YOUR_DNSDIST_CONSOLE_KEY>"

# PowerDNS API keys
export PDNS_PRIMARY_API_KEY="<YOUR_PDNS_PRIMARY_API_KEY>"
export PDNS_SECONDARY_API_KEY="<YOUR_PDNS_SECONDARY_API_KEY>"

# PowerDNS webserver settings
export PDNS_WEBSERVER_PORT="8081"
export PDNS_WEBSERVER_ALLOW_FROM="127.0.0.1/32" # e.g., 127.0.0.1/32,192.168.x.0/24

# PowerDNS primary specific settings
export PDNS_PRIMARY_ALLOW_AXFR_IPS="<YOUR_PDNS_PRIMARY_ALLOW_AXFR_IPS>" # e.g., 192.168.x.11
export PDNS_PRIMARY_ALSO_NOTIFY="<YOUR_PDNS_PRIMARY_ALSO_NOTIFY_IPS>" # e.g., 192.168.x.11

# --- Proxmox Playbook Variables (playbooks/proxmox.yml) ---
# User for Proxmox maintenance
export MAINTENANCE_USER="<YOUR_MAINTENANCE_USERNAME>"
# Hashed password for the maintenance user (e.g., generated by 'mkpasswd -m sha-512')
export MAINTENANCE_PASSWORD_HASH="<YOUR_MAINTENANCE_PASSWORD_HASH>"
# Path to the SSH public key file (e.g., /home/youruser/.ssh/id_rsa.pub)
export SSH_KEY_PATH="<PATH_TO_YOUR_SSH_PUBLIC_KEY>"
