kubeProxyReplacement: true
k8sServiceHost: {{ requiredEnv "K0S_CONTROLLER_ADDRESSES" | splitList "," | first | trim }}
k8sServicePort: 6443
l2announcements:
  enabled: true
externalIPs:
  enabled: true
ingressController:
  enabled: true
  loadbalancerMode: dedicated
gatewayAPI:
  enabled: true
operator:
  replicas: 1
