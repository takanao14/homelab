      "title": "Unreachable Nodes",
      "description": "Nodes Cilium cannot reach via the health checker.",
      "transparent": false,
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "gridPos": {
        "h": 4,
        "w": 5,
        "x": 10,
        "y": 1
      },
      "repeatDirection": "h",
      "options": {
