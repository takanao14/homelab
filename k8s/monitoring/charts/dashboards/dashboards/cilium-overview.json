          "expr": "sum by (cluster) (cilium_datapath_conntrack_gc_entries{cluster=~\"$cluster\"})",
          "legendFormat": "{{cluster}}"
        }
      ],
      "title": "Conntrack GC Entries",
      "description": "Connection-tracking entries seen by the last garbage-collection run.",
      "transparent": false,
