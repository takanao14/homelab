    {
      "type": "row",
      "collapsed": false,
      "title": "Hubble Diagnostics",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 5
      },
      "id": 0,
      "panels": []
    },
    {
      "type": "timeseries",
      "targets": [
        {
          "expr": "ceil(sum by (cluster, node, source) (increase(hubble_lost_events_total{cluster=~\"$cluster\"}[5m])))",
          "legendFormat": "{{cluster}} {{node}} {{source}}"
        }
      ],
      "title": "Hubble Lost Events by Node / Source (5m)",
      "description": "Rolling 5-minute lost event count by node and pipeline stage. hubble_ring_buffer indicates a slow reader; observer_events_queue indicates Hubble processing backlog; perf_event_ring_buffer indicates datapath-to-userspace loss.",
      "transparent": false,
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 6
      },
      "repeatDirection": "h",
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true,
          "calcs": []
        },
        "tooltip": {
          "mode": "multi",
          "sort": ""
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "custom": {}
        },
        "overrides": []
      }
    },
    {
      "type": "row",
      "collapsed": false,
      "title": "Drops \u0026 Policy",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 14
      },
      "id": 0,
      "panels": []
    },
    {
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum by (cluster, reason) (rate(cilium_drop_count_total{cluster=~\"$cluster\"}[5m]))",
          "legendFormat": "{{cluster}} {{reason}}"
        }
      ],
      "title": "Drop Rate by Reason",
      "description": "Packets dropped by the datapath, by reason. Some reasons (e.g. unsupported L3 protocol) are benign background noise.",
      "transparent": false,
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 15
      },
      "repeatDirection": "h",
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
