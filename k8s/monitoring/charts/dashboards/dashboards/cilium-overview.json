          "calcs": []
        },
        "tooltip": {
          "mode": "multi",
          "sort": ""
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "pps",
          "min": 0,
          "custom": {}
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum by (cluster, verdict) (rate(hubble_flows_processed_total{cluster=~\"$cluster\"}[5m]))",
          "legendFormat": "{{cluster}} {{verdict}}"
        }
      ],
      "title": "Hubble Flow Verdicts",
      "description": "Observed network flows by verdict. DROPPED flows indicate policy denials or datapath drops.",
      "transparent": false,
      "datasource": {
        "type": "prometheus",
