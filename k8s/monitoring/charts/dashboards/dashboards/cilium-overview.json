    {
      "type": "stat",
      "targets": [
        {
          "expr": "ceil(sum(increase(cilium_errors_warnings_total{cluster=~\"$cluster\",level=\"ERROR\"}[5m]))) or vector(0)",
          "legendFormat": "Errors"
        }
      ],
      "title": "Agent Errors (5m)",
      "description": "Cilium agent log messages at ERROR level in the last 5 minutes.",
      "transparent": false,
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "gridPos": {
        "h": 4,
        "w": 5,
        "x": 15,
        "y": 1
      },
      "repeatDirection": "h",
      "options": {
        "graphMode": "area",
        "colorMode": "background",
        "justifyMode": "auto",
        "textMode": "auto",
        "wideLayout": true,
        "showPercentChange": false,
        "reduceOptions": {
          "calcs": []
