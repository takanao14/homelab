      "type": "stat",
      "targets": [
        {
          "expr": "ceil(sum(increase(hubble_lost_events_total{cluster=~\"$cluster\"}[5m]))) or vector(0)",
          "legendFormat": "Lost"
        }
      ],
      "title": "Hubble Lost Events (5m)",
      "description": "Hubble events lost at any processing stage in the last 5 minutes. See the node/source breakdown below for the cause.",
      "transparent": false,
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 20,
        "y": 1
      },
      "repeatDirection": "h",
      "options": {
        "graphMode": "area",
