      "gridPos": {
        "h": 8,
        "w": 20,
        "x": 4,
        "y": 10
      },
      "repeatDirection": "h",
      "options": {
        "frameIndex": 0,
        "showHeader": true,
        "showTypeIcons": false,
        "footer": {
          "show": false,
          "reducer": null,
          "countRows": false
        },
        "cellHeight": "sm"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "inspect": false
          }
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum by (integration, reason) (rate(alertmanager_notifications_failed_total[$__rate_interval])) \u003e 0 or on() vector(0)",
          "legendFormat": "{{integration}} {{reason}}"
        }
      ],
      "title": "Alertmanager Notification Failures",
      "description": "Failed Alertmanager notification requests grouped by integration and reason.",
      "transparent": false,
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
