{
  "uid": "syslog",
  "title": "Syslog",
  "tags": [
    "syslog",
    "network",
    "logs",
    "infrastructure"
  ],
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "time": {
    "from": "now-3h",
    "to": "now"
  },
  "fiscalYearStartMonth": 0,
  "refresh": "60s",
  "schemaVersion": 42,
  "panels": [
    {
      "type": "row",
      "collapsed": false,
      "title": "Summary",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 0,
      "panels": []
    },
    {
      "type": "stat",
      "targets": [
        {
          "expr": "sum(rate({host=~\"$host\", severity=~\"$severity\"}[5m])) or vector(0)",
          "legendFormat": "logs/s",
          "instant": true
        }
      ],
      "title": "Log Rate",
      "transparent": false,
      "datasource": {
        "type": "loki",
        "uid": "$datasource"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 1
      },
      "repeatDirection": "h",
      "options": {
        "graphMode": "area",
        "colorMode": "value",
        "justifyMode": "auto",
        "textMode": "auto",
        "wideLayout": true,
        "showPercentChange": false,
        "reduceOptions": {
          "calcs": []
        },
        "percentChangeColorMode": "standard",
        "orientation": ""
      },
      "fieldConfig": {
        "defaults": {
          "unit": "cps",
          "min": 0
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "targets": [
        {
          "expr": "sum(count_over_time({host=~\"$host\", severity=~\"emerg|alert|crit|err|error|[0-3]\"} [1h])) or vector(0)",
          "legendFormat": "errors",
          "instant": true
        }
      ],
      "title": "Errors (1h)",
      "transparent": false,
      "datasource": {
        "type": "loki",
        "uid": "$datasource"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 1
      },
      "repeatDirection": "h",
      "options": {
        "graphMode": "area",
        "colorMode": "value",
        "justifyMode": "auto",
        "textMode": "auto",
        "wideLayout": true,
        "showPercentChange": false,
        "reduceOptions": {
          "calcs": []
        },
        "percentChangeColorMode": "standard",
        "orientation": ""
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "green"
              },
              {
                "value": 1,
                "color": "red"
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "targets": [
        {
          "expr": "sum(count_over_time({host=~\"$host\", severity=~\"warning|warn|4\"} [1h])) or vector(0)",
          "legendFormat": "warnings",
          "instant": true
        }
      ],
      "title": "Warnings (1h)",
      "transparent": false,
      "datasource": {
        "type": "loki",
        "uid": "$datasource"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 1
      },
      "repeatDirection": "h",
      "options": {
        "graphMode": "area",
        "colorMode": "value",
        "justifyMode": "auto",
        "textMode": "auto",
        "wideLayout": true,
        "showPercentChange": false,
        "reduceOptions": {
          "calcs": []
        },
        "percentChangeColorMode": "standard",
        "orientation": ""
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "green"
              },
              {
                "value": 1,
                "color": "yellow"
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "targets": [
        {
          "expr": "sum(count_over_time({host=~\"$host\"} | json | __error__!=\"\" [1h])) or vector(0)",
          "legendFormat": "errors",
          "instant": true
        }
      ],
      "title": "Parse Errors (1h)",
      "transparent": false,
      "datasource": {
        "type": "loki",
        "uid": "$datasource"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 1
      },
      "repeatDirection": "h",
      "options": {
        "graphMode": "area",
        "colorMode": "value",
        "justifyMode": "auto",
        "textMode": "auto",
        "wideLayout": true,
        "showPercentChange": false,
        "reduceOptions": {
          "calcs": []
        },
        "percentChangeColorMode": "standard",
        "orientation": ""
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "green"
              },
              {
                "value": 1,
                "color": "red"
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "type": "row",
      "collapsed": false,
      "title": "Volume Trends",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 5
      },
      "id": 0,
      "panels": []
    },
    {
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum by (host) (rate({host=~\"$host\", severity=~\"$severity\"}[5m]))",
          "legendFormat": "{{host}}"
        }
      ],
      "title": "Log Volume by Host",
      "transparent": false,
      "datasource": {
        "type": "loki",
        "uid": "$datasource"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 6
      },
      "repeatDirection": "h",
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true,
          "calcs": []
        },
        "tooltip": {
          "mode": "multi",
          "sort": ""
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "cps",
          "min": 0,
          "custom": {
            "fillOpacity": 10,
            "stacking": {
              "mode": "normal"
            },
            "spanNulls": true
          }
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum by (severity) (rate({host=~\"$host\", severity=~\".+\"}[5m]))",
          "legendFormat": "{{severity}}"
        }
      ],
      "title": "Log Volume by Severity",
      "transparent": false,
      "datasource": {
        "type": "loki",
        "uid": "$datasource"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 6
      },
      "repeatDirection": "h",
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true,
          "calcs": []
        },
        "tooltip": {
          "mode": "multi",
          "sort": ""
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "cps",
          "min": 0,
          "custom": {
            "fillOpacity": 10,
            "stacking": {
              "mode": "normal"
            },
            "spanNulls": true
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byRegexp",
              "options": "/^(emerg|alert|crit|err|error|[0-3])$/"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "red",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byRegexp",
              "options": "/^(warning|warn|4)$/"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "yellow",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byRegexp",
              "options": "/^(notice|5)$/"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "blue",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byRegexp",
              "options": "/^(info|6)$/"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "green",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      }
    },
    {
      "type": "row",
      "collapsed": false,
      "title": "App Breakdown",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 14
      },
      "id": 0,
      "panels": []
    },
    {
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum by (appname) (rate({host=~\"$host\", severity=~\"$severity\"} | json | __error__=\"\" | appname=~\"$appname\"[5m]))",
          "legendFormat": "{{appname}}"
        }
      ],
      "title": "Log Volume by App",
      "transparent": false,
      "datasource": {
        "type": "loki",
        "uid": "$datasource"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 15
      },
      "repeatDirection": "h",
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true,
          "calcs": []
        },
        "tooltip": {
          "mode": "multi",
          "sort": ""
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "cps",
          "min": 0,
          "custom": {
            "fillOpacity": 10,
            "stacking": {
              "mode": "normal"
            },
            "spanNulls": true
          }
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum by (host) (rate({host=~\"$host\", severity=~\"emerg|alert|crit|err|error|[0-3]\"}[5m])) or sum by (host) (rate({host=~\"$host\", severity=~\"$severity\"}[5m])) * 0",
          "legendFormat": "{{host}}"
        }
      ],
      "title": "Error Rate by Host",
      "transparent": false,
      "datasource": {
        "type": "loki",
        "uid": "$datasource"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 15
      },
      "repeatDirection": "h",
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true,
          "calcs": []
        },
        "tooltip": {
          "mode": "multi",
          "sort": ""
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "cps",
          "min": 0,
          "custom": {
            "fillOpacity": 10,
            "spanNulls": true
          }
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum by (host) (rate({host=~\"$host\", severity=~\"warning|warn|4\"}[5m])) or sum by (host) (rate({host=~\"$host\", severity=~\"$severity\"}[5m])) * 0",
          "legendFormat": "{{host}}"
        }
      ],
      "title": "Warning Rate by Host",
      "transparent": false,
      "datasource": {
        "type": "loki",
        "uid": "$datasource"
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 23
      },
      "repeatDirection": "h",
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true,
          "calcs": []
        },
        "tooltip": {
          "mode": "multi",
          "sort": ""
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "cps",
          "min": 0,
          "custom": {
            "fillOpacity": 10,
            "spanNulls": true
          }
        },
        "overrides": []
      }
    },
    {
      "type": "row",
      "collapsed": false,
      "title": "Logs",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 31
      },
      "id": 0,
      "panels": []
    },
    {
      "type": "logs",
      "targets": [
        {
          "expr": "{host=~\"$host\", severity=~\"$severity\"} | json | __error__=\"\" | appname=~\"$appname\" | line_format \"{{.host}} [{{.severity}}] {{.appname}}: {{.message}}\"",
          "maxLines": 500
        }
      ],
      "title": "Syslog",
      "transparent": false,
      "datasource": {
        "type": "loki",
        "uid": "$datasource"
      },
      "gridPos": {
        "h": 12,
        "w": 24,
        "x": 0,
        "y": 32
      },
      "repeatDirection": "h",
      "options": {
        "showLabels": false,
        "showCommonLabels": false,
        "showTime": true,
        "showLogContextToggle": false,
        "wrapLogMessage": false,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": ""
      }
    }
  ],
  "templating": {
    "list": [
      {
        "type": "datasource",
        "name": "datasource",
        "label": "Datasource",
        "skipUrlSync": false,
        "query": "loki",
        "multi": false,
        "allowCustomValue": true,
        "includeAll": false,
        "auto": false,
        "auto_min": "10s",
        "auto_count": 30
      },
      {
        "type": "query",
        "name": "host",
        "label": "Host",
        "skipUrlSync": false,
        "query": "label_values(host)",
        "datasource": {
          "type": "loki",
          "uid": "$datasource"
        },
        "multi": true,
        "allowCustomValue": true,
        "refresh": 2,
        "sort": 1,
        "includeAll": true,
        "auto": false,
        "auto_min": "10s",
        "auto_count": 30
      },
      {
        "type": "query",
        "name": "severity",
        "label": "Severity",
        "skipUrlSync": false,
        "query": "label_values(severity)",
        "datasource": {
          "type": "loki",
          "uid": "$datasource"
        },
        "multi": true,
        "allowCustomValue": true,
        "refresh": 2,
        "sort": 1,
        "includeAll": true,
        "auto": false,
        "auto_min": "10s",
        "auto_count": 30
      },
      {
        "type": "query",
        "name": "appname",
        "label": "App",
        "skipUrlSync": false,
        "query": "label_values(appname)",
        "datasource": {
          "type": "loki",
          "uid": "$datasource"
        },
        "multi": true,
        "allowCustomValue": true,
        "refresh": 2,
        "sort": 1,
        "includeAll": true,
        "auto": false,
        "auto_min": "10s",
        "auto_count": 30
      }
    ]
  },
  "annotations": {}
}