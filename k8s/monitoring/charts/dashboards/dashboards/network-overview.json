{
  "uid": "network-overview",
  "title": "Network Overview",
  "tags": [
    "network",
    "infrastructure"
  ],
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "time": {
    "from": "now-30d",
    "to": "now"
  },
  "fiscalYearStartMonth": 0,
  "refresh": "60s",
  "schemaVersion": 42,
  "panels": [
    {
      "type": "row",
      "collapsed": false,
      "title": "Summary",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 0,
      "panels": []
    },
    {
      "type": "stat",
      "targets": [
        {
          "expr": "count by (instance) (ifOperStatus{ifDescr=~\"GigaEthernet[0-9]+|GigabitEthernet[0-9]+\", instance=~\"$instance\"} == 1)",
          "legendFormat": "{{instance}}"
        }
      ],
      "title": "Interfaces Up",
      "transparent": false,
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 1
      },
      "repeatDirection": "h",
      "options": {
        "graphMode": "area",
        "colorMode": "value",
        "justifyMode": "auto",
        "textMode": "auto",
        "wideLayout": true,
        "showPercentChange": false,
        "reduceOptions": {
          "calcs": []
        },
        "percentChangeColorMode": "standard",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "targets": [
        {
          "expr": "count by (instance) (ifOperStatus{ifDescr=~\"GigaEthernet[0-9]+|GigabitEthernet[0-9]+\", instance=~\"$instance\"} != 1) or count by (instance) (ifOperStatus{ifDescr=~\"GigaEthernet[0-9]+|GigabitEthernet[0-9]+\", instance=~\"$instance\"}) * 0",
          "legendFormat": "{{instance}}"
        }
      ],
      "title": "Interfaces Down",
      "transparent": false,
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 1
      },
      "repeatDirection": "h",
      "options": {
        "graphMode": "area",
        "colorMode": "background",
        "justifyMode": "auto",
        "textMode": "auto",
        "wideLayout": true,
        "showPercentChange": false,
        "reduceOptions": {
          "calcs": []
        },
        "percentChangeColorMode": "standard",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "green"
              },
              {
                "value": 1,
                "color": "red"
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "targets": [
        {
          "expr": "sum by (instance) (rate(ifHCInOctets{ifDescr=~\"GigaEthernet[0-9]+|GigabitEthernet[0-9]+\", instance=~\"$instance\"}[$__rate_interval]) * 8)",
          "legendFormat": "{{instance}} In"
        },
        {
          "expr": "sum by (instance) (rate(ifHCOutOctets{ifDescr=~\"GigaEthernet[0-9]+|GigabitEthernet[0-9]+\", instance=~\"$instance\"}[$__rate_interval]) * 8)",
          "legendFormat": "{{instance}} Out"
        }
      ],
      "title": "Total Traffic",
      "transparent": false,
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "gridPos": {
        "h": 4,
        "w": 12,
        "x": 12,
        "y": 1
      },
      "repeatDirection": "h",
      "options": {
        "graphMode": "area",
        "colorMode": "value",
        "justifyMode": "auto",
        "textMode": "auto",
        "wideLayout": true,
        "showPercentChange": false,
        "reduceOptions": {
          "calcs": []
        },
        "percentChangeColorMode": "standard",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bps",
          "min": 0
        },
        "overrides": []
      }
    },
    {
      "type": "row",
      "collapsed": false,
      "title": "Traffic",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 5
      },
      "id": 0,
      "panels": []
    },
    {
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum by (instance) (rate(ifHCInOctets{ifDescr=~\"GigaEthernet[0-9]+|GigabitEthernet[0-9]+\", instance=~\"$instance\"}[$__rate_interval]) * 8)",
          "legendFormat": "{{instance}} In",
          "refId": "In"
        },
        {
          "expr": "sum by (instance) (rate(ifHCOutOctets{ifDescr=~\"GigaEthernet[0-9]+|GigabitEthernet[0-9]+\", instance=~\"$instance\"}[$__rate_interval]) * 8)",
          "legendFormat": "{{instance}} Out",
          "refId": "Out"
        }
      ],
      "title": "Traffic (bps)",
      "transparent": false,
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 6
      },
      "repeatDirection": "h",
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true,
          "calcs": []
        },
        "tooltip": {
          "mode": "multi",
          "sort": ""
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "transparent"
              },
              {
                "value": 0,
                "color": "white"
              }
            ]
          },
          "custom": {
            "thresholdsStyle": {
              "mode": "line"
            }
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byFrameRefID",
              "options": "Out"
            },
            "properties": [
              {
                "id": "custom.transform",
                "value": "negative-Y"
              }
            ]
          }
        ]
      }
    },
    {
      "type": "row",
      "collapsed": false,
      "title": "Errors \u0026 Discards",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 14
      },
      "id": 0,
      "panels": []
    },
    {
      "type": "timeseries",
      "targets": [
        {
          "expr": "rate(ifInErrors{ifDescr=~\"GigaEthernet[0-9]+|GigabitEthernet[0-9]+\", instance=~\"$instance\"}[$__rate_interval])",
          "legendFormat": "{{instance}} {{ifDescr}} In"
        },
        {
          "expr": "rate(ifOutErrors{ifDescr=~\"GigaEthernet[0-9]+|GigabitEthernet[0-9]+\", instance=~\"$instance\"}[$__rate_interval])",
          "legendFormat": "{{instance}} {{ifDescr}} Out"
        }
      ],
      "title": "Interface Errors",
      "transparent": false,
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 15
      },
      "repeatDirection": "h",
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true,
          "calcs": []
        },
        "tooltip": {
          "mode": "multi",
          "sort": ""
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "pps",
          "min": 0,
          "custom": {}
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "targets": [
        {
          "expr": "rate(ifInDiscards{ifDescr=~\"GigaEthernet[0-9]+|GigabitEthernet[0-9]+\", instance=~\"$instance\"}[$__rate_interval])",
          "legendFormat": "{{instance}} {{ifDescr}} In"
        },
        {
          "expr": "rate(ifOutDiscards{ifDescr=~\"GigaEthernet[0-9]+|GigabitEthernet[0-9]+\", instance=~\"$instance\"}[$__rate_interval])",
          "legendFormat": "{{instance}} {{ifDescr}} Out"
        }
      ],
      "title": "Interface Discards",
      "transparent": false,
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 15
      },
      "repeatDirection": "h",
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true,
          "calcs": []
        },
        "tooltip": {
          "mode": "multi",
          "sort": ""
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "pps",
          "min": 0,
          "custom": {}
        },
        "overrides": []
      }
    }
  ],
  "templating": {
    "list": [
      {
        "type": "datasource",
        "name": "datasource",
        "label": "Datasource",
        "skipUrlSync": false,
        "query": "prometheus",
        "multi": false,
        "allowCustomValue": true,
        "includeAll": false,
        "auto": false,
        "auto_min": "10s",
        "auto_count": 30
      },
      {
        "type": "custom",
        "name": "instance",
        "label": "Device",
        "skipUrlSync": false,
        "query": "bgw1,c1200",
        "multi": true,
        "allowCustomValue": true,
        "includeAll": true,
        "auto": false,
        "auto_min": "10s",
        "auto_count": 30
      }
    ]
  },
  "annotations": {}
}