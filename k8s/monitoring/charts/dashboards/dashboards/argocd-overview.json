{
  "uid": "argocd-overview",
  "title": "ArgoCD Overview",
  "tags": [
    "argocd",
    "gitops",
    "infrastructure"
  ],
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "fiscalYearStartMonth": 0,
  "refresh": "1m",
  "schemaVersion": 42,
  "panels": [
    {
      "type": "row",
      "collapsed": false,
      "title": "Summary",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 0,
      "panels": []
    },
    {
      "type": "stat",
      "targets": [
        {
          "expr": "count(argocd_app_info{cluster=~\"$cluster\",health_status!=\"Healthy\"}) or vector(0)",
          "legendFormat": "Not Healthy"
        }
      ],
      "title": "Apps Not Healthy",
      "description": "Applications whose health status is not Healthy.",
      "transparent": false,
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 1
      },
      "repeatDirection": "h",
      "options": {
        "graphMode": "area",
        "colorMode": "background",
        "justifyMode": "auto",
        "textMode": "auto",
        "wideLayout": true,
        "showPercentChange": false,
        "reduceOptions": {
          "calcs": []
        },
        "percentChangeColorMode": "standard",
        "orientation": ""
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "green"
              },
              {
                "value": 1,
                "color": "red"
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "targets": [
        {
          "expr": "count(argocd_app_info{cluster=~\"$cluster\",sync_status!=\"Synced\"}) or vector(0)",
          "legendFormat": "OutOfSync"
        }
      ],
      "title": "Apps OutOfSync",
      "description": "Applications whose sync status is not Synced.",
      "transparent": false,
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 1
      },
      "repeatDirection": "h",
      "options": {
        "graphMode": "area",
        "colorMode": "background",
        "justifyMode": "auto",
        "textMode": "auto",
        "wideLayout": true,
        "showPercentChange": false,
        "reduceOptions": {
          "calcs": []
        },
        "percentChangeColorMode": "standard",
        "orientation": ""
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "green"
              },
              {
                "value": 1,
                "color": "red"
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "targets": [
        {
          "expr": "ceil(sum(increase(argocd_app_sync_total{cluster=~\"$cluster\",phase=~\"Error|Failed\"}[1h]))) or vector(0)",
          "legendFormat": "Failures"
        }
      ],
      "title": "Sync Failures (1h)",
      "description": "Sync operations that ended in Error or Failed in the last hour.",
      "transparent": false,
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 1
      },
      "repeatDirection": "h",
      "options": {
        "graphMode": "area",
        "colorMode": "background",
        "justifyMode": "auto",
        "textMode": "auto",
        "wideLayout": true,
        "showPercentChange": false,
        "reduceOptions": {
          "calcs": []
        },
        "percentChangeColorMode": "standard",
        "orientation": ""
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "green"
              },
              {
                "value": 1,
                "color": "red"
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "targets": [
        {
          "expr": "count(argocd_cluster_connection_status{cluster=~\"$cluster\"} == 0) or vector(0)",
          "legendFormat": "Down"
        }
      ],
      "title": "Cluster Connections Down",
      "description": "Destination clusters the application-controller cannot reach.",
      "transparent": false,
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 1
      },
      "repeatDirection": "h",
      "options": {
        "graphMode": "area",
        "colorMode": "background",
        "justifyMode": "auto",
        "textMode": "auto",
        "wideLayout": true,
        "showPercentChange": false,
        "reduceOptions": {
          "calcs": []
        },
        "percentChangeColorMode": "standard",
        "orientation": ""
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "green"
              },
              {
                "value": 1,
                "color": "red"
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "type": "row",
      "collapsed": false,
      "title": "Applications",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 5
      },
      "id": 0,
      "panels": []
    },
    {
      "type": "timeseries",
      "targets": [
        {
          "expr": "count by (cluster, health_status) (argocd_app_info{cluster=~\"$cluster\"})",
          "legendFormat": "{{cluster}} {{health_status}}"
        }
      ],
      "title": "Apps by Health Status",
      "description": "Application count per health status.",
      "transparent": false,
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 6
      },
      "repeatDirection": "h",
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true,
          "calcs": []
        },
        "tooltip": {
          "mode": "multi",
          "sort": ""
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "fillOpacity": 10,
            "stacking": {
              "mode": "normal"
            }
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byRegexp",
              "options": ".* Healthy"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "green",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byRegexp",
              "options": ".* (Degraded|Missing)"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "red",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byRegexp",
              "options": ".* Progressing"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "yellow",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      }
    },
    {
      "type": "timeseries",
      "targets": [
        {
          "expr": "count by (cluster, sync_status) (argocd_app_info{cluster=~\"$cluster\"})",
          "legendFormat": "{{cluster}} {{sync_status}}"
        }
      ],
      "title": "Apps by Sync Status",
      "description": "Application count per sync status.",
      "transparent": false,
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 6
      },
      "repeatDirection": "h",
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true,
          "calcs": []
        },
        "tooltip": {
          "mode": "multi",
          "sort": ""
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "fillOpacity": 10,
            "stacking": {
              "mode": "normal"
            }
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byRegexp",
              "options": ".* Synced"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "green",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byRegexp",
              "options": ".* OutOfSync"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "orange",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      }
    },
    {
      "type": "table",
      "targets": [
        {
          "expr": "argocd_app_info{cluster=~\"$cluster\",health_status!=\"Healthy\"} or argocd_app_info{cluster=~\"$cluster\",sync_status!=\"Synced\"}",
          "format": "table",
          "instant": true,
          "range": false
        }
      ],
      "title": "Apps Needing Attention",
      "description": "Applications that are not Healthy or not Synced. Empty is good.",
      "transparent": false,
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "gridPos": {
        "h": 6,
        "w": 24,
        "x": 0,
        "y": 14
      },
      "repeatDirection": "h",
      "transformations": [
        {
          "id": "organize",
          "options": {
            "includeByName": {
              "cluster": true,
              "dest_namespace": true,
              "health_status": true,
              "name": true,
              "project": true,
              "sync_status": true
            },
            "indexByName": {
              "cluster": 0,
              "dest_namespace": 3,
              "health_status": 4,
              "name": 1,
              "project": 2,
              "sync_status": 5
            },
            "renameByName": {
              "dest_namespace": "Namespace",
              "health_status": "Health",
              "name": "Application",
              "project": "Project",
              "sync_status": "Sync"
            }
          }
        }
      ],
      "options": {
        "frameIndex": 0,
        "showHeader": true,
        "showTypeIcons": false,
        "footer": {
          "show": false,
          "reducer": null,
          "countRows": false
        },
        "cellHeight": "sm"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "inspect": false
          }
        },
        "overrides": []
      }
    },
    {
      "type": "row",
      "collapsed": false,
      "title": "Sync \u0026 Reconcile",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 20
      },
      "id": 0,
      "panels": []
    },
    {
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum by (cluster, phase) (rate(argocd_app_sync_total{cluster=~\"$cluster\"}[$__rate_interval]))",
          "legendFormat": "{{cluster}} {{phase}}"
        }
      ],
      "title": "Sync Activity",
      "description": "Sync operations per second by result phase.",
      "transparent": false,
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 21
      },
      "repeatDirection": "h",
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true,
          "calcs": []
        },
        "tooltip": {
          "mode": "multi",
          "sort": ""
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {}
        },
        "overrides": [
          {
            "matcher": {
              "id": "byRegexp",
              "options": ".* (Error|Failed)"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "red",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byRegexp",
              "options": ".* Succeeded"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "green",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      }
    },
    {
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (cluster, le) (rate(argocd_app_reconcile_bucket{cluster=~\"$cluster\"}[$__rate_interval])))",
          "legendFormat": "{{cluster}} p99"
        },
        {
          "expr": "histogram_quantile(0.50, sum by (cluster, le) (rate(argocd_app_reconcile_bucket{cluster=~\"$cluster\"}[$__rate_interval])))",
          "legendFormat": "{{cluster}} p50"
        }
      ],
      "title": "App Reconcile Latency",
      "description": "Application reconciliation duration percentiles in the application-controller.",
      "transparent": false,
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 21
      },
      "repeatDirection": "h",
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true,
          "calcs": []
        },
        "tooltip": {
          "mode": "multi",
          "sort": ""
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {}
        },
        "overrides": []
      }
    },
    {
      "type": "row",
      "collapsed": false,
      "title": "repo-server",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 29
      },
      "id": 0,
      "panels": []
    },
    {
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum by (cluster, request_type) (rate(argocd_git_request_total{cluster=~\"$cluster\"}[$__rate_interval]))",
          "legendFormat": "{{cluster}} {{request_type}}"
        }
      ],
      "title": "Git Requests",
      "description": "Git requests per second from the repo-server, by request type.",
      "transparent": false,
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 30
      },
      "repeatDirection": "h",
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true,
          "calcs": []
        },
        "tooltip": {
          "mode": "multi",
          "sort": ""
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {}
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (cluster, request_type, le) (rate(argocd_git_request_duration_seconds_bucket{cluster=~\"$cluster\"}[$__rate_interval])))",
          "legendFormat": "{{cluster}} {{request_type}}"
        }
      ],
      "title": "Git Request Duration p95",
      "description": "95th percentile git request duration, by request type. Slow fetches point at repo size or network issues.",
      "transparent": false,
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 30
      },
      "repeatDirection": "h",
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true,
          "calcs": []
        },
        "tooltip": {
          "mode": "multi",
          "sort": ""
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {}
        },
        "overrides": []
      }
    }
  ],
  "templating": {
    "list": [
      {
        "type": "datasource",
        "name": "datasource",
        "label": "Datasource",
        "skipUrlSync": false,
        "query": "prometheus",
        "multi": false,
        "allowCustomValue": true,
        "includeAll": false,
        "auto": false,
        "auto_min": "10s",
        "auto_count": 30
      },
      {
        "type": "query",
        "name": "cluster",
        "label": "Cluster",
        "skipUrlSync": false,
        "query": "label_values(argocd_app_info, cluster)",
        "datasource": {
          "type": "prometheus",
          "uid": "$datasource"
        },
        "multi": true,
        "allowCustomValue": true,
        "refresh": 2,
        "sort": 1,
        "includeAll": true,
        "auto": false,
        "auto_min": "10s",
        "auto_count": 30
      }
    ]
  },
  "annotations": {}
}