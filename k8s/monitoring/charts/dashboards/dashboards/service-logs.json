{
  "uid": "service-logs",
  "title": "Service Logs",
  "tags": [
    "logs",
    "infrastructure",
    "journald"
  ],
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "time": {
    "from": "now-3h",
    "to": "now"
  },
  "fiscalYearStartMonth": 0,
  "refresh": "60s",
  "schemaVersion": 42,
  "panels": [
    {
      "type": "row",
      "collapsed": false,
      "title": "Summary",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 0,
      "panels": []
    },
    {
      "type": "stat",
      "targets": [
        {
          "expr": "sum(rate({host=~\"$host\", unit=~\"$unit\"}[5m])) or vector(0)",
          "legendFormat": "logs/s",
          "instant": true
        }
      ],
      "title": "Log Rate",
      "transparent": false,
      "datasource": {
        "type": "loki",
        "uid": "$datasource"
      },
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 0,
        "y": 1
      },
      "repeatDirection": "h",
      "options": {
        "graphMode": "area",
        "colorMode": "value",
        "justifyMode": "auto",
        "textMode": "auto",
        "wideLayout": true,
        "showPercentChange": false,
        "reduceOptions": {
          "calcs": []
        },
        "percentChangeColorMode": "standard",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "cps",
          "min": 0
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "targets": [
        {
          "expr": "sum(count_over_time({host=~\"$host\", unit=~\"$unit\"} | json | __error__=\"\" | PRIORITY =~ \"[0-3]\" [1h])) or vector(0)",
          "legendFormat": "errors",
          "instant": true
        }
      ],
      "title": "Errors (1h)",
      "transparent": false,
      "datasource": {
        "type": "loki",
        "uid": "$datasource"
      },
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 8,
        "y": 1
      },
      "repeatDirection": "h",
      "options": {
        "graphMode": "area",
        "colorMode": "value",
        "justifyMode": "auto",
        "textMode": "auto",
        "wideLayout": true,
        "showPercentChange": false,
        "reduceOptions": {
          "calcs": []
        },
        "percentChangeColorMode": "standard",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "green"
              },
              {
                "value": 1,
                "color": "red"
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "targets": [
        {
          "expr": "sum(count_over_time({host=~\"$host\", unit=~\"$unit\"} | json | __error__=\"\" | PRIORITY = \"4\" [1h])) or vector(0)",
          "legendFormat": "warnings",
          "instant": true
        }
      ],
      "title": "Warnings (1h)",
      "transparent": false,
      "datasource": {
        "type": "loki",
        "uid": "$datasource"
      },
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 16,
        "y": 1
      },
      "repeatDirection": "h",
      "options": {
        "graphMode": "area",
        "colorMode": "value",
        "justifyMode": "auto",
        "textMode": "auto",
        "wideLayout": true,
        "showPercentChange": false,
        "reduceOptions": {
          "calcs": []
        },
        "percentChangeColorMode": "standard",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "green"
              },
              {
                "value": 1,
                "color": "yellow"
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "type": "row",
      "collapsed": false,
      "title": "Volume Trends",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 5
      },
      "id": 0,
      "panels": []
    },
    {
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum by (host) (rate({host=~\"$host\", unit=~\"$unit\"}[5m]))",
          "legendFormat": "{{host}}"
        }
      ],
      "title": "Log Volume by Host",
      "transparent": false,
      "datasource": {
        "type": "loki",
        "uid": "$datasource"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 6
      },
      "repeatDirection": "h",
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true,
          "calcs": []
        },
        "tooltip": {
          "mode": "multi",
          "sort": ""
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "cps",
          "min": 0,
          "custom": {
            "fillOpacity": 10,
            "stacking": {
              "mode": "normal"
            },
            "spanNulls": true
          }
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum by (unit) (rate({host=~\"$host\", unit=~\"$unit\"}[5m]))",
          "legendFormat": "{{unit}}"
        }
      ],
      "title": "Log Volume by Unit",
      "transparent": false,
      "datasource": {
        "type": "loki",
        "uid": "$datasource"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 6
      },
      "repeatDirection": "h",
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true,
          "calcs": []
        },
        "tooltip": {
          "mode": "multi",
          "sort": ""
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "cps",
          "min": 0,
          "custom": {
            "fillOpacity": 10,
            "stacking": {
              "mode": "normal"
            },
            "spanNulls": true
          }
        },
        "overrides": []
      }
    },
    {
      "type": "row",
      "collapsed": false,
      "title": "Errors and Warnings",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 14
      },
      "id": 0,
      "panels": []
    },
    {
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum by (unit) (rate({host=~\"$host\", unit=~\"$unit\"} | json | __error__=\"\" | PRIORITY =~ \"[0-3]\" [5m])) or sum by (unit) (rate({host=~\"$host\", unit=~\"$unit\"}[5m])) * 0",
          "legendFormat": "{{unit}}"
        }
      ],
      "title": "Error Rate by Unit",
      "transparent": false,
      "datasource": {
        "type": "loki",
        "uid": "$datasource"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 15
      },
      "repeatDirection": "h",
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true,
          "calcs": []
        },
        "tooltip": {
          "mode": "multi",
          "sort": ""
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "cps",
          "min": 0,
          "custom": {
            "fillOpacity": 10,
            "spanNulls": true
          }
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum by (unit) (rate({host=~\"$host\", unit=~\"$unit\"} | json | __error__=\"\" | PRIORITY = \"4\" [5m])) or sum by (unit) (rate({host=~\"$host\", unit=~\"$unit\"}[5m])) * 0",
          "legendFormat": "{{unit}}"
        }
      ],
      "title": "Warning Rate by Unit",
      "transparent": false,
      "datasource": {
        "type": "loki",
        "uid": "$datasource"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 15
      },
      "repeatDirection": "h",
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true,
          "calcs": []
        },
        "tooltip": {
          "mode": "multi",
          "sort": ""
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "cps",
          "min": 0,
          "custom": {
            "fillOpacity": 10,
            "spanNulls": true
          }
        },
        "overrides": []
      }
    },
    {
      "type": "row",
      "collapsed": false,
      "title": "Logs",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 23
      },
      "id": 0,
      "panels": []
    },
    {
      "type": "logs",
      "targets": [
        {
          "expr": "{host=~\"$host\", unit=~\"$unit\"} | json | __error__=\"\" | line_format \"{{.message}}\"",
          "maxLines": 500
        }
      ],
      "title": "Service Logs",
      "transparent": false,
      "datasource": {
        "type": "loki",
        "uid": "$datasource"
      },
      "gridPos": {
        "h": 12,
        "w": 24,
        "x": 0,
        "y": 24
      },
      "repeatDirection": "h",
      "options": {
        "showLabels": false,
        "showCommonLabels": false,
        "showTime": true,
        "showLogContextToggle": false,
        "wrapLogMessage": false,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": ""
      }
    }
  ],
  "templating": {
    "list": [
      {
        "type": "datasource",
        "name": "datasource",
        "label": "Datasource",
        "skipUrlSync": false,
        "query": "loki",
        "multi": false,
        "allowCustomValue": true,
        "includeAll": false,
        "auto": false,
        "auto_min": "10s",
        "auto_count": 30
      },
      {
        "type": "query",
        "name": "host",
        "label": "Host",
        "skipUrlSync": false,
        "query": "label_values(host)",
        "datasource": {
          "type": "loki",
          "uid": "$datasource"
        },
        "multi": true,
        "allowCustomValue": true,
        "refresh": 2,
        "sort": 1,
        "includeAll": true,
        "auto": false,
        "auto_min": "10s",
        "auto_count": 30
      },
      {
        "type": "query",
        "name": "unit",
        "label": "Unit",
        "skipUrlSync": false,
        "query": "label_values({host=~\"$host\"}, unit)",
        "datasource": {
          "type": "loki",
          "uid": "$datasource"
        },
        "multi": true,
        "allowCustomValue": true,
        "refresh": 2,
        "sort": 1,
        "includeAll": true,
        "auto": false,
        "auto_min": "10s",
        "auto_count": 30
      }
    ]
  },
  "annotations": {}
}