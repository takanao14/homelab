{
  "uid": "cert-manager-overview",
  "title": "cert-manager Overview",
  "tags": [
    "cert-manager",
    "certificates",
    "infrastructure"
  ],
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "time": {
    "from": "now-7d",
    "to": "now"
  },
  "fiscalYearStartMonth": 0,
  "refresh": "5m",
  "schemaVersion": 42,
  "panels": [
    {
      "type": "row",
      "collapsed": false,
      "title": "Summary",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 0,
      "panels": []
    },
    {
      "type": "stat",
      "targets": [
        {
          "expr": "count(certmanager_certificate_ready_status{cluster=~\"$cluster\",condition=\"True\"} != 1) or vector(0)",
          "legendFormat": "Not Ready"
        }
      ],
      "title": "Certs Not Ready",
      "description": "Certificates where the Ready condition is not True.",
      "transparent": false,
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 0,
        "y": 1
      },
      "repeatDirection": "h",
      "options": {
        "graphMode": "area",
        "colorMode": "background",
        "justifyMode": "auto",
        "textMode": "auto",
        "wideLayout": true,
        "showPercentChange": false,
        "reduceOptions": {
          "calcs": []
        },
        "percentChangeColorMode": "standard",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "green"
              },
              {
                "value": 1,
                "color": "red"
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "targets": [
        {
          "expr": "count(certmanager_clusterissuer_ready_status{cluster=~\"$cluster\",condition=\"True\"} != 1) or vector(0)",
          "legendFormat": "Not Ready"
        }
      ],
      "title": "ClusterIssuers Not Ready",
      "description": "ClusterIssuers where the Ready condition is not True.",
      "transparent": false,
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 8,
        "y": 1
      },
      "repeatDirection": "h",
      "options": {
        "graphMode": "area",
        "colorMode": "background",
        "justifyMode": "auto",
        "textMode": "auto",
        "wideLayout": true,
        "showPercentChange": false,
        "reduceOptions": {
          "calcs": []
        },
        "percentChangeColorMode": "standard",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "green"
              },
              {
                "value": 1,
                "color": "red"
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "targets": [
        {
          "expr": "ceil(sum(increase(certmanager_controller_sync_error_count{cluster=~\"$cluster\"}[1h]))) or vector(0)",
          "legendFormat": "Errors"
        }
      ],
      "title": "Sync Errors (1h)",
      "description": "cert-manager controller reconciliation errors in the last hour.",
      "transparent": false,
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 16,
        "y": 1
      },
      "repeatDirection": "h",
      "options": {
        "graphMode": "area",
        "colorMode": "background",
        "justifyMode": "auto",
        "textMode": "auto",
        "wideLayout": true,
        "showPercentChange": false,
        "reduceOptions": {
          "calcs": []
        },
        "percentChangeColorMode": "standard",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "green"
              },
              {
                "value": 1,
                "color": "red"
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "type": "row",
      "collapsed": false,
      "title": "Certificates",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 5
      },
      "id": 0,
      "panels": []
    },
    {
      "type": "table",
      "targets": [
        {
          "expr": "sort((certmanager_certificate_expiration_timestamp_seconds{cluster=~\"$cluster\"} - time()) / 86400)",
          "format": "table",
          "instant": true,
          "range": false,
          "refId": "A"
        },
        {
          "expr": "sort((certmanager_certificate_renewal_timestamp_seconds{cluster=~\"$cluster\"} - time()) / 86400)",
          "format": "table",
          "instant": true,
          "range": false,
          "refId": "B"
        },
        {
          "expr": "certmanager_certificate_ready_status{cluster=~\"$cluster\",condition=\"True\"}",
          "format": "table",
          "instant": true,
          "range": false,
          "refId": "C"
        }
      ],
      "title": "Certificate Status",
      "description": "Expiry, renewal schedule, and ready state for each certificate. Days Until Renewal shows when cert-manager will begin renewal attempts; negative means renewal is already in progress.",
      "transparent": false,
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 6
      },
      "repeatDirection": "h",
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "condition": true,
              "container": true,
              "endpoint": true,
              "instance": true,
              "issuer_kind": true,
              "namespace": true,
              "pod": true,
              "prometheus": true,
              "prometheus_replica": true,
              "service": true
            },
            "indexByName": {
              "Value #A": 5,
              "Value #B": 6,
              "Value #C": 4,
              "cluster": 0,
              "exported_namespace": 1,
              "issuer_name": 3,
              "name": 2
            },
            "renameByName": {
              "Value #A": "Days Until Expiry",
              "Value #B": "Days Until Renewal",
              "Value #C": "Ready",
              "exported_namespace": "Namespace",
              "issuer_name": "Issuer",
              "name": "Certificate"
            }
          }
        }
      ],
      "options": {
        "frameIndex": 0,
        "showHeader": true,
        "showTypeIcons": false,
        "footer": {
          "show": false,
          "reducer": null,
          "countRows": false
        },
        "cellHeight": "sm"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "inspect": false
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Days Until Expiry"
            },
            "properties": [
              {
                "id": "unit",
                "value": "d"
              },
              {
                "id": "decimals",
                "value": 1
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "red",
                      "value": null
                    },
                    {
                      "color": "orange",
                      "value": 7
                    },
                    {
                      "color": "green",
                      "value": 21
                    }
                  ]
                }
              },
              {
                "id": "custom.displayMode",
                "value": "color-background"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Days Until Renewal"
            },
            "properties": [
              {
                "id": "unit",
                "value": "d"
              },
              {
                "id": "decimals",
                "value": 1
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Ready"
            },
            "properties": [
              {
                "id": "decimals",
                "value": 0
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "red",
                      "value": null
                    },
                    {
                      "color": "green",
                      "value": 1
                    }
                  ]
                }
              },
              {
                "id": "custom.displayMode",
                "value": "color-background"
              },
              {
                "id": "mappings",
                "value": [
                  {
                    "options": {
                      "0": {
                        "index": 0,
                        "text": "Not Ready"
                      },
                      "1": {
                        "index": 1,
                        "text": "Ready"
                      }
                    },
                    "type": "value"
                  }
                ]
              }
            ]
          }
        ]
      }
    },
    {
      "type": "timeseries",
      "targets": [
        {
          "expr": "(certmanager_certificate_expiration_timestamp_seconds{cluster=~\"$cluster\"} - time()) / 86400",
          "legendFormat": "{{cluster}} {{exported_namespace}}/{{name}}"
        }
      ],
      "title": "Days Until Expiry",
      "description": "Certificate expiry countdown. A jump upward indicates a successful renewal.",
      "transparent": false,
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 16
      },
      "repeatDirection": "h",
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true,
          "calcs": []
        },
        "tooltip": {
          "mode": "multi",
          "sort": ""
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "d",
          "min": 0,
          "custom": {}
        },
        "overrides": []
      }
    },
    {
      "type": "row",
      "collapsed": false,
      "title": "ClusterIssuers",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 24
      },
      "id": 0,
      "panels": []
    },
    {
      "type": "table",
      "targets": [
        {
          "expr": "certmanager_clusterissuer_ready_status{cluster=~\"$cluster\",condition=\"True\"}",
          "format": "table",
          "instant": true,
          "legendFormat": "{{cluster}} {{name}}",
          "range": false
        }
      ],
      "title": "ClusterIssuer Status",
      "description": "Ready state of each ClusterIssuer.",
      "transparent": false,
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "gridPos": {
        "h": 6,
        "w": 24,
        "x": 0,
        "y": 25
      },
      "repeatDirection": "h",
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "condition": true,
              "container": true,
              "endpoint": true,
              "instance": true,
              "namespace": true,
              "pod": true,
              "prometheus": true,
              "prometheus_replica": true,
              "service": true
            },
            "indexByName": {
              "Value": 2,
              "cluster": 0,
              "name": 1
            },
            "renameByName": {
              "Value": "Ready",
              "name": "Issuer"
            }
          }
        }
      ],
      "options": {
        "frameIndex": 0,
        "showHeader": true,
        "showTypeIcons": false,
        "footer": {
          "show": false,
          "reducer": null,
          "countRows": false
        },
        "cellHeight": "sm"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "inspect": false
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Ready"
            },
            "properties": [
              {
                "id": "decimals",
                "value": 0
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "red",
                      "value": null
                    },
                    {
                      "color": "green",
                      "value": 1
                    }
                  ]
                }
              },
              {
                "id": "custom.displayMode",
                "value": "color-background"
              },
              {
                "id": "mappings",
                "value": [
                  {
                    "options": {
                      "0": {
                        "index": 0,
                        "text": "Not Ready"
                      },
                      "1": {
                        "index": 1,
                        "text": "Ready"
                      }
                    },
                    "type": "value"
                  }
                ]
              }
            ]
          }
        ]
      }
    }
  ],
  "templating": {
    "list": [
      {
        "type": "datasource",
        "name": "datasource",
        "label": "Datasource",
        "skipUrlSync": false,
        "query": "prometheus",
        "multi": false,
        "allowCustomValue": true,
        "includeAll": false,
        "auto": false,
        "auto_min": "10s",
        "auto_count": 30
      },
      {
        "type": "query",
        "name": "cluster",
        "label": "Cluster",
        "skipUrlSync": false,
        "query": "label_values(kube_node_info, cluster)",
        "datasource": {
          "type": "prometheus",
          "uid": "$datasource"
        },
        "multi": true,
        "allowCustomValue": true,
        "refresh": 2,
        "sort": 1,
        "includeAll": true,
        "auto": false,
        "auto_min": "10s",
        "auto_count": 30
      }
    ]
  },
  "annotations": {}
}