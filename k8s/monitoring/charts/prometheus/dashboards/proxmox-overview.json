        "x": 12,
        "y": 0
      },
      "repeatDirection": "h",
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "targets": [
        {
          "expr": "sum by (node) ((pve_up{id=~\"lxc/.*\", instance=~\"$instance(:.*)?\"} * on(id, instance) group_left(node) pve_guest_info) == bool 0)",
