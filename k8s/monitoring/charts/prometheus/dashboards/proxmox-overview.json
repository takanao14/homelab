{
  "uid": "proxmox-overview",
  "title": "Proxmox Overview",
  "tags": [
    "proxmox",
    "infrastructure"
  ],
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "time": {
    "from": "now-1d",
    "to": "now"
  },
  "fiscalYearStartMonth": 0,
  "refresh": "30s",
  "schemaVersion": 42,
  "panels": [
    {
      "type": "stat",
      "targets": [
        {
          "expr": "count by (node) ((pve_up{id=~\"qemu/.*\", instance=~\"$instance(:.*)?\"} == 1) * on(id, instance) group_left(node) pve_guest_info)",
          "legendFormat": "{{node}}"
        }
      ],
      "title": "Running VMs",
      "transparent": false,
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "repeatDirection": "h",
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "targets": [
        {
          "expr": "sum by (node) ((pve_up{id=~\"qemu/.*\", instance=~\"$instance(:.*)?\"} * on(id, instance) group_left(node) pve_guest_info) == bool 0)",
          "legendFormat": "{{node}}"
        }
      ],
      "title": "Stopped VMs",
      "transparent": false,
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "repeatDirection": "h",
      "options": {
        "graphMode": "area",
        "colorMode": "background",
        "justifyMode": "auto",
        "textMode": "auto",
        "wideLayout": true,
        "showPercentChange": false,
        "reduceOptions": {
          "calcs": []
        },
        "percentChangeColorMode": "standard",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "green"
              },
              {
                "value": 1,
                "color": "red"
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "targets": [
        {
          "expr": "count by (node) ((pve_up{id=~\"lxc/.*\", instance=~\"$instance(:.*)?\"} == 1) * on(id, instance) group_left(node) pve_guest_info)",
          "legendFormat": "{{node}}"
        }
      ],
      "title": "Running LXCs",
      "transparent": false,
