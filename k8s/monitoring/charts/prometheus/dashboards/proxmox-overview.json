          "expr": "pve_memory_usage_bytes{id=~\"node/.*\", instance=~\"$instance(:.*)?\"} / pve_memory_size_bytes{id=~\"node/.*\", instance=~\"$instance(:.*)?\"} * 100 * on(id, instance) group_left(name) pve_node_info",
