            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "green"
              },
              {
                "value": 1,
                "color": "red"
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "targets": [
        {
          "expr": "pve_cpu_usage_ratio{id=~\"node/.*\", instance=~\"$instance(:.*)?\"} * on(id, instance) group_left(name) pve_node_info",
          "legendFormat": "{{name}}"
