        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 0,
      "panels": []
    },
    {
      "type": "stat",
      "targets": [
        {
          "expr": "amd_gpu_gfx_activity{job=\"scrapeConfig/monitoring/amd-gpu-external\"}",
          "legendFormat": "GFX Activity"
        }
      ],
      "title": "GFX Activity",
      "transparent": false,
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 1
      },
      "repeatDirection": "h",
