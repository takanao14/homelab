{
  "uid": "network-overview",
  "title": "Network Overview",
  "tags": [
    "network",
    "infrastructure"
  ],
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "time": {
    "from": "now-1d",
    "to": "now"
  },
  "fiscalYearStartMonth": 0,
  "refresh": "60s",
  "schemaVersion": 42,
  "panels": [
    {
      "type": "row",
      "collapsed": false,
      "title": "Summary",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 0,
      "panels": []
    },
    {
      "type": "stat",
      "targets": [
        {
          "expr": "label_replace(label_replace(count by (instance) (ifOperStatus{ifDescr!~\"Loopback.*|Null.*|bluetooth.*\", instance=~\"$instance\"} == 1), \"device\", \"bgw1\", \"instance\", \"192.168.10.1.*\"), \"device\", \"c1200\", \"instance\", \"192.168.10.2.*\")",
          "legendFormat": "{{device}}"
        }
      ],
      "title": "Interfaces Up",
      "transparent": false,
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 1
      },
      "repeatDirection": "h",
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "targets": [
        {
          "expr": "label_replace(label_replace(count by (instance) (ifOperStatus{ifDescr!~\"Loopback.*|Null.*|bluetooth.*\", instance=~\"$instance\"} != 1) or vector(0), \"device\", \"bgw1\", \"instance\", \"192.168.10.1.*\"), \"device\", \"c1200\", \"instance\", \"192.168.10.2.*\")",
          "legendFormat": "{{device}}"
        }
      ],
      "title": "Interfaces Down",
      "transparent": false,
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 1
      },
      "repeatDirection": "h",
      "options": {
        "graphMode": "area",
        "colorMode": "background",
        "justifyMode": "auto",
        "textMode": "auto",
        "wideLayout": true,
        "showPercentChange": false,
        "reduceOptions": {
          "calcs": []
        },
        "percentChangeColorMode": "standard",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "green"
              },
              {
                "value": 1,
                "color": "red"
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "targets": [
        {
          "expr": "label_replace(label_replace(sum by (instance) (rate(ifHCInOctets{ifDescr!~\"Loopback.*|Null.*|bluetooth.*\", instance=~\"$instance\"}[5m]) * 8), \"device\", \"bgw1\", \"instance\", \"192.168.10.1.*\"), \"device\", \"c1200\", \"instance\", \"192.168.10.2.*\")",
          "legendFormat": "{{device}} In"
        },
        {
          "expr": "label_replace(label_replace(sum by (instance) (rate(ifHCOutOctets{ifDescr!~\"Loopback.*|Null.*|bluetooth.*\", instance=~\"$instance\"}[5m]) * 8), \"device\", \"bgw1\", \"instance\", \"192.168.10.1.*\"), \"device\", \"c1200\", \"instance\", \"192.168.10.2.*\")",
          "legendFormat": "{{device}} Out"
        }
      ],
      "title": "Total Traffic",
      "transparent": false,
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "gridPos": {
        "h": 4,
        "w": 12,
        "x": 12,
        "y": 1
      },
      "repeatDirection": "h",
      "fieldConfig": {
        "defaults": {
          "unit": "bps"
        },
        "overrides": []
      }
    },
    {
      "type": "row",
      "collapsed": false,
      "title": "Traffic",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 5
      },
      "id": 0,
      "panels": []
    },
    {
      "type": "timeseries",
      "targets": [
        {
          "expr": "label_replace(label_replace(sum by (instance) (rate(ifHCInOctets{ifDescr!~\"Loopback.*|Null.*|bluetooth.*\", instance=~\"$instance\"}[5m]) * 8), \"device\", \"bgw1\", \"instance\", \"192.168.10.1.*\"), \"device\", \"c1200\", \"instance\", \"192.168.10.2.*\")",
          "legendFormat": "{{device}} In",
          "refId": "In"
        },
        {
          "expr": "label_replace(label_replace(sum by (instance) (rate(ifHCOutOctets{ifDescr!~\"Loopback.*|Null.*|bluetooth.*\", instance=~\"$instance\"}[5m]) * 8), \"device\", \"bgw1\", \"instance\", \"192.168.10.1.*\"), \"device\", \"c1200\", \"instance\", \"192.168.10.2.*\")",
          "legendFormat": "{{device}} Out",
          "refId": "Out"
        }
      ],
      "title": "Traffic (bps)",
      "transparent": false,
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 6
      },
      "repeatDirection": "h",
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": false,
          "calcs": []
        },
        "tooltip": {
          "mode": "multi",
          "sort": ""
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bps"
        },
        "overrides": [
          {
            "matcher": {
              "id": "byFrameRefID",
              "options": "Out"
            },
            "properties": [
              {
                "id": "custom.transform",
                "value": "negative-Y"
              }
            ]
          }
        ]
      }
    },
    {
      "type": "row",
      "collapsed": false,
      "title": "Errors \u0026 Discards",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 14
      },
      "id": 0,
      "panels": []
    },
    {
      "type": "timeseries",
      "targets": [
        {
          "expr": "label_replace(label_replace(rate(ifInErrors{ifDescr!~\"Loopback.*|Null.*|bluetooth.*\", instance=~\"$instance\"}[5m]), \"device\", \"bgw1\", \"instance\", \"192.168.10.1.*\"), \"device\", \"c1200\", \"instance\", \"192.168.10.2.*\")",
          "legendFormat": "{{device}} {{ifDescr}} In"
        },
        {
          "expr": "label_replace(label_replace(rate(ifOutErrors{ifDescr!~\"Loopback.*|Null.*|bluetooth.*\", instance=~\"$instance\"}[5m]), \"device\", \"bgw1\", \"instance\", \"192.168.10.1.*\"), \"device\", \"c1200\", \"instance\", \"192.168.10.2.*\")",
          "legendFormat": "{{device}} {{ifDescr}} Out"
        }
      ],
      "title": "Interface Errors",
      "transparent": false,
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 15
      },
      "repeatDirection": "h",
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": false,
          "calcs": []
        },
        "tooltip": {
          "mode": "multi",
          "sort": ""
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "pps"
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "targets": [
        {
          "expr": "label_replace(label_replace(rate(ifInDiscards{ifDescr!~\"Loopback.*|Null.*|bluetooth.*\", instance=~\"$instance\"}[5m]), \"device\", \"bgw1\", \"instance\", \"192.168.10.1.*\"), \"device\", \"c1200\", \"instance\", \"192.168.10.2.*\")",
          "legendFormat": "{{device}} {{ifDescr}} In"
        },
        {
          "expr": "label_replace(label_replace(rate(ifOutDiscards{ifDescr!~\"Loopback.*|Null.*|bluetooth.*\", instance=~\"$instance\"}[5m]), \"device\", \"bgw1\", \"instance\", \"192.168.10.1.*\"), \"device\", \"c1200\", \"instance\", \"192.168.10.2.*\")",
          "legendFormat": "{{device}} {{ifDescr}} Out"
        }
      ],
      "title": "Interface Discards",
      "transparent": false,
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 15
      },
      "repeatDirection": "h",
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": false,
          "calcs": []
        },
        "tooltip": {
          "mode": "multi",
          "sort": ""
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "pps"
        },
        "overrides": []
      }
    }
  ],
  "templating": {
    "list": [
      {
        "type": "datasource",
        "name": "datasource",
        "label": "Datasource",
        "skipUrlSync": false,
        "query": "prometheus",
        "multi": false,
        "allowCustomValue": true,
        "includeAll": false,
        "auto": false,
        "auto_min": "10s",
        "auto_count": 30
      },
      {
        "type": "custom",
        "name": "instance",
        "label": "Device",
        "skipUrlSync": false,
        "query": "192.168.10.1,192.168.10.2",
        "multi": true,
        "allowCustomValue": true,
        "includeAll": true,
        "auto": false,
        "auto_min": "10s",
        "auto_count": 30
      }
    ]
  },
  "annotations": {}
}