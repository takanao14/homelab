{
  "uid": "disk-health",
  "title": "Disk Health (S.M.A.R.T.)",
  "tags": [
    "disk",
    "smart",
    "infrastructure"
  ],
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "time": {
    "from": "now-7d",
    "to": "now"
  },
  "fiscalYearStartMonth": 0,
  "refresh": "5m",
  "schemaVersion": 42,
  "panels": [
    {
      "type": "row",
      "collapsed": false,
      "title": "Summary",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 0,
      "panels": []
    },
    {
      "type": "stat",
      "targets": [
        {
          "expr": "sum(smartmon_device_smart_healthy{instance=~\"$instance\"} == bool 0)",
          "legendFormat": "Unhealthy"
        }
      ],
      "title": "Unhealthy Disks",
      "transparent": false,
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 0,
        "y": 1
      },
      "repeatDirection": "h",
      "options": {
        "graphMode": "none",
        "colorMode": "background",
        "justifyMode": "auto",
        "textMode": "auto",
        "wideLayout": true,
        "showPercentChange": false,
        "reduceOptions": {
          "calcs": []
        },
        "percentChangeColorMode": "standard",
        "orientation": ""
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "green"
              },
              {
                "value": 1,
                "color": "red"
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "targets": [
        {
          "expr": "count(smartmon_device_smart_healthy{instance=~\"$instance\"})",
          "legendFormat": "Disks"
        }
      ],
      "title": "Disks Monitored",
      "transparent": false,
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 8,
        "y": 1
      },
      "repeatDirection": "h",
      "options": {
        "graphMode": "none",
        "colorMode": "background",
        "justifyMode": "auto",
        "textMode": "auto",
        "wideLayout": true,
        "showPercentChange": false,
        "reduceOptions": {
          "calcs": []
        },
        "percentChangeColorMode": "standard",
        "orientation": ""
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "blue"
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "targets": [
        {
          "expr": "sum(smartmon_wear_leveling_count_value{instance=~\"$instance\"} \u003c bool 10)",
          "legendFormat": "Worn"
        }
      ],
      "title": "SSDs Worn (\u003c10% life)",
      "transparent": false,
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 16,
        "y": 1
      },
      "repeatDirection": "h",
      "options": {
        "graphMode": "none",
        "colorMode": "background",
        "justifyMode": "auto",
        "textMode": "auto",
        "wideLayout": true,
        "showPercentChange": false,
        "reduceOptions": {
          "calcs": []
        },
        "percentChangeColorMode": "standard",
        "orientation": ""
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "green"
              },
              {
                "value": 1,
                "color": "red"
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "targets": [
        {
          "expr": "smartmon_device_smart_healthy{instance=~\"$instance\"} * on(instance) group_left(nodename) max by (instance, nodename) (node_uname_info)",
          "legendFormat": "{{nodename}} {{disk}} ({{type}})"
        }
      ],
      "title": "SMART Health",
      "transparent": false,
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "gridPos": {
        "h": 4,
        "w": 24,
        "x": 0,
        "y": 5
      },
      "repeatDirection": "h",
      "options": {
        "graphMode": "none",
        "colorMode": "background",
        "justifyMode": "auto",
        "textMode": "auto",
        "wideLayout": true,
        "showPercentChange": false,
        "reduceOptions": {
          "calcs": []
        },
        "percentChangeColorMode": "standard",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "FAIL",
                  "color": "red"
                },
                "1": {
                  "text": "OK",
                  "color": "green"
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "red"
              },
              {
                "value": 1,
                "color": "green"
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "type": "row",
      "collapsed": false,
      "title": "Failure Precursors (SATA)",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 9
      },
      "id": 0,
      "panels": []
    },
    {
      "type": "bargauge",
      "targets": [
        {
          "expr": "sort_desc(smartmon_reallocated_sector_ct_raw_value{instance=~\"$instance\"} * on(instance) group_left(nodename) max by (instance, nodename) (node_uname_info))",
          "legendFormat": "{{nodename}} {{disk}}"
        }
      ],
      "title": "Reallocated Sectors",
      "transparent": false,
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 10
      },
      "repeatDirection": "h",
      "options": {
        "displayMode": "gradient",
        "valueMode": "color",
        "namePlacement": "auto",
        "showUnfilled": true,
        "sizing": "auto",
        "minVizWidth": 8,
        "minVizHeight": 16,
        "legend": {
          "displayMode": "list",
