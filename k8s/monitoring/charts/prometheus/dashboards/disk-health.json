          "expr": "smartmon_wear_leveling_count_value{instance=~\"$instance\"} * on(instance) group_left(nodename) max by (instance, nodename) (node_uname_info)",
          "legendFormat": "{{nodename}} {{disk}}"
        }
      ],
      "title": "SSD Life Remaining (normalized)",
      "transparent": false,
      "datasource": {
