          "expr": "sort_desc(smartmon_offline_uncorrectable_raw_value{instance=~\"$instance\"} * on(instance) group_left(nodename) max by (instance, nodename) (node_uname_info))",
          "legendFormat": "{{nodename}} {{disk}}"
