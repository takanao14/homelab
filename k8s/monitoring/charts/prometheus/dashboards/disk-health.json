      "targets": [
        {
          "expr": "sort_desc(smartmon_current_pending_sector_raw_value{instance=~\"$instance\"} * on(instance) group_left(nodename) max by (instance, nodename) (node_uname_info))",
          "legendFormat": "{{nodename}} {{disk}}"
        }
      ],
      "title": "Current Pending Sectors",
      "transparent": false,
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 10
