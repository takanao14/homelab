{
  "uid": "node-overview",
  "title": "Node Overview",
  "tags": [
    "nodes",
    "infrastructure"
  ],
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "time": {
    "from": "now-1d",
    "to": "now"
  },
  "fiscalYearStartMonth": 0,
  "refresh": "30s",
  "schemaVersion": 42,
  "panels": [
    {
      "type": "row",
      "collapsed": false,
      "title": "Summary",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 0,
      "panels": []
    },
    {
      "type": "bargauge",
      "targets": [
        {
          "expr": "100 - (avg by (nodename) (rate(node_cpu_seconds_total{mode=\"idle\", instance=~\"$instance\"}[5m]) * on(instance) group_left(nodename) max by (instance, nodename) (node_uname_info)) * 100)",
          "legendFormat": "{{nodename}}"
        }
      ],
      "title": "CPU Usage",
      "transparent": false,
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 1
      },
      "repeatDirection": "h",
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1
        },
        "overrides": []
      }
    },
    {
      "type": "bargauge",
      "targets": [
        {
          "expr": "(1 - node_memory_MemAvailable_bytes{instance=~\"$instance\"} / node_memory_MemTotal_bytes{instance=~\"$instance\"}) * on(instance) group_left(nodename) max by (instance, nodename) (node_uname_info) * 100",
          "legendFormat": "{{nodename}}"
        }
      ],
      "title": "Memory Usage",
      "transparent": false,
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 1
      },
      "repeatDirection": "h",
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "targets": [
        {
          "expr": "(node_load1{instance=~\"$instance\"} / on(instance) group_left() count by (instance) (node_cpu_seconds_total{mode=\"idle\", instance=~\"$instance\"})) * on(instance) group_left(nodename) max by (instance, nodename) (node_uname_info)",
          "legendFormat": "{{nodename}}"
        }
      ],
      "title": "Load Average (1m) per CPU",
      "transparent": false,
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "gridPos": {
        "h": 4,
        "w": 12,
        "x": 0,
        "y": 9
      },
      "repeatDirection": "h",
      "options": {
        "graphMode": "area",
        "colorMode": "background",
        "justifyMode": "auto",
        "textMode": "auto",
        "wideLayout": true,
        "showPercentChange": false,
        "reduceOptions": {
          "calcs": []
        },
        "percentChangeColorMode": "standard",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "green"
              },
              {
                "value": 0.7,
                "color": "yellow"
              },
              {
                "value": 1,
                "color": "red"
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "targets": [
        {
          "expr": "(time() - node_boot_time_seconds{instance=~\"$instance\"}) * on(instance) group_left(nodename) max by (instance, nodename) (node_uname_info)",
          "legendFormat": "{{nodename}}"
        }
      ],
      "title": "Uptime",
      "transparent": false,
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "gridPos": {
        "h": 4,
        "w": 12,
        "x": 12,
        "y": 9
      },
      "repeatDirection": "h",
      "options": {
        "graphMode": "none",
        "colorMode": "background",
        "justifyMode": "auto",
        "textMode": "auto",
        "wideLayout": true,
        "showPercentChange": false,
        "reduceOptions": {
          "calcs": []
        },
        "percentChangeColorMode": "standard",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "red"
              },
              {
                "value": 3600,
                "color": "yellow"
              },
              {
                "value": 86400,
                "color": "green"
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "type": "row",
      "collapsed": false,
      "title": "CPU",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 13
      },
      "id": 0,
      "panels": []
    },
    {
      "type": "timeseries",
      "targets": [
        {
          "expr": "100 - (avg by (nodename) (rate(node_cpu_seconds_total{mode=\"idle\", instance=~\"$instance\"}[5m]) * on(instance) group_left(nodename) max by (instance, nodename) (node_uname_info)) * 100)",
          "legendFormat": "{{nodename}}"
        }
      ],
      "title": "CPU Usage (%)",
      "transparent": false,
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 14
      },
      "repeatDirection": "h",
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": false,
          "calcs": []
        },
        "tooltip": {
          "mode": "multi",
          "sort": ""
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent"
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "targets": [
        {
          "expr": "(node_load1{instance=~\"$instance\"} / on(instance) group_left() count by (instance) (node_cpu_seconds_total{mode=\"idle\", instance=~\"$instance\"})) * on(instance) group_left(nodename) max by (instance, nodename) (node_uname_info)",
          "legendFormat": "{{nodename}}"
        }
      ],
      "title": "Load Average per CPU (1m)",
      "transparent": false,
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 22
      },
      "repeatDirection": "h",
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": false,
          "calcs": []
        },
        "tooltip": {
          "mode": "multi",
          "sort": ""
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit"
        },
        "overrides": []
      }
    },
    {
      "type": "row",
      "collapsed": false,
      "title": "Memory",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 30
      },
      "id": 0,
      "panels": []
    },
    {
      "type": "timeseries",
      "targets": [
        {
          "expr": "(node_memory_MemTotal_bytes{instance=~\"$instance\"} - node_memory_MemAvailable_bytes{instance=~\"$instance\"}) * on(instance) group_left(nodename) max by (instance, nodename) (node_uname_info)",
          "legendFormat": "{{nodename}}"
        }
      ],
      "title": "Memory Used",
      "transparent": false,
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 31
      },
      "repeatDirection": "h",
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": false,
          "calcs": []
        },
        "tooltip": {
          "mode": "multi",
          "sort": ""
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        },
        "overrides": []
      }
    },
    {
      "type": "row",
      "collapsed": false,
      "title": "Temperature \u0026 Throttling",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 39
      },
      "id": 0,
      "panels": []
    },
    {
      "type": "timeseries",
      "targets": [
        {
          "expr": "((label_replace(node_thermal_zone_temp{type=~\"x86_pkg_temp|cpu-thermal\", instance=~\"$instance\"}, \"sensor\", \"$1\", \"type\", \"(.*)\")) or (label_replace(node_hwmon_temp_celsius{chip=~\".*_0000:00:18_.*\", sensor=\"temp1\", instance=~\"$instance\"}, \"sensor\", \"cpu\", \"\", \"\"))) * on(instance) group_left(nodename) max by (instance, nodename) (node_uname_info)",
          "legendFormat": "{{nodename}} CPU {{sensor}}"
        },
        {
          "expr": "(nvme_temperature_celsius{instance=~\"$instance\"}) * on(instance) group_left(nodename) max by (instance, nodename) (node_uname_info)",
          "legendFormat": "{{nodename}} NVMe {{device}}"
        },
        {
          "expr": "(smartmon_temperature_celsius_raw_value{instance=~\"$instance\"}) * on(instance) group_left(nodename) max by (instance, nodename) (node_uname_info)",
          "legendFormat": "{{nodename}} Disk {{device}}"
        }
      ],
      "title": "Temperature",
      "transparent": false,
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 40
      },
      "repeatDirection": "h",
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": false,
          "calcs": []
        },
        "tooltip": {
          "mode": "multi",
          "sort": ""
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "celsius"
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "targets": [
        {
          "expr": "(rate(node_cpu_package_throttles_total{instance=~\"$instance\"}[5m])) * on(instance) group_left(nodename) max by (instance, nodename) (node_uname_info)",
          "legendFormat": "{{nodename}} Throttles"
        },
        {
          "expr": "(rpi_throttled_thermal_throttling{instance=~\"$instance\"}) * on(instance) group_left(nodename) max by (instance, nodename) (node_uname_info)",
          "legendFormat": "{{nodename}} RPi Thermal Throttled"
        },
        {
          "expr": "(rpi_throttled_occurred{instance=~\"$instance\"}) * on(instance) group_left(nodename) max by (instance, nodename) (node_uname_info)",
          "legendFormat": "{{nodename}} RPi Thermal Throttled Occurred"
        },
        {
          "expr": "(rpi_throttled_under_voltage{instance=~\"$instance\"}) * on(instance) group_left(nodename) max by (instance, nodename) (node_uname_info)",
          "legendFormat": "{{nodename}} RPi Under Voltage"
        },
        {
          "expr": "(rpi_throttled_under_voltage_occurred{instance=~\"$instance\"}) * on(instance) group_left(nodename) max by (instance, nodename) (node_uname_info)",
          "legendFormat": "{{nodename}} RPi Under Voltage Occurred"
        }
      ],
      "title": "CPU Throttling \u0026 Power Issues",
      "transparent": false,
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 40
      },
      "repeatDirection": "h",
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": false,
          "calcs": []
        },
        "tooltip": {
          "mode": "multi",
          "sort": ""
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        },
        "overrides": []
      }
    },
    {
      "type": "row",
      "collapsed": false,
      "title": "Disk",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 48
      },
      "id": 0,
      "panels": []
    },
    {
      "type": "timeseries",
      "targets": [
        {
          "expr": "rate(node_disk_read_bytes_total{instance=~\"$instance\", device=~\"[svh]d[a-z]+|nvme[0-9]+n[0-9]+|mmcblk[0-9]+\"}[5m]) * on(instance) group_left(nodename) max by (instance, nodename) (node_uname_info)",
          "legendFormat": "{{nodename}} Read {{device}}"
        },
        {
          "expr": "rate(node_disk_written_bytes_total{instance=~\"$instance\", device=~\"[svh]d[a-z]+|nvme[0-9]+n[0-9]+|mmcblk[0-9]+\"}[5m]) * on(instance) group_left(nodename) max by (instance, nodename) (node_uname_info)",
          "legendFormat": "{{nodename}} Write {{device}}"
        }
      ],
      "title": "Disk I/O",
      "transparent": false,
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 49
      },
      "repeatDirection": "h",
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": false,
          "calcs": []
        },
        "tooltip": {
          "mode": "multi",
          "sort": ""
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps"
        },
        "overrides": []
      }
    },
    {
      "type": "row",
      "collapsed": false,
      "title": "Network",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 57
      },
      "id": 0,
      "panels": []
    },
    {
      "type": "timeseries",
      "targets": [
        {
          "expr": "rate(node_network_receive_bytes_total{instance=~\"$instance\", device!~\"lo|veth.*|docker.*|br-.*|fwbr.*|fwpr.*|fwln.*|tap.*|tun.*|virbr.*|cilium.*\"}[5m]) * on(instance) group_left(nodename) max by (instance, nodename) (node_uname_info)",
          "legendFormat": "{{nodename}} Rx {{device}}",
          "refId": "Rx"
        },
        {
          "expr": "rate(node_network_transmit_bytes_total{instance=~\"$instance\", device!~\"lo|veth.*|docker.*|br-.*|fwbr.*|fwpr.*|fwln.*|tap.*|tun.*|virbr.*|cilium.*\"}[5m]) * on(instance) group_left(nodename) max by (instance, nodename) (node_uname_info)",
          "legendFormat": "{{nodename}} Tx {{device}}",
          "refId": "Tx"
        }
      ],
      "title": "Network I/O",
      "transparent": false,
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 58
      },
      "repeatDirection": "h",
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": false,
          "calcs": []
        },
        "tooltip": {
          "mode": "multi",
          "sort": ""
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps"
        },
        "overrides": [
          {
            "matcher": {
              "id": "byFrameRefID",
              "options": "Tx"
            },
            "properties": [
              {
                "id": "custom.transform",
                "value": "negative-Y"
              }
            ]
          }
        ]
      }
    },
    {
      "type": "bargauge",
      "targets": [
        {
          "expr": "sort_desc((1 - node_filesystem_avail_bytes{instance=~\"$instance\",fstype=~\"ext[234]|xfs|btrfs|zfs|vfat\",mountpoint!~\"/var/lib/docker/.*\"} / node_filesystem_size_bytes{instance=~\"$instance\",fstype=~\"ext[234]|xfs|btrfs|zfs|vfat\",mountpoint!~\"/var/lib/docker/.*\"}) * 100) * on(instance) group_left(nodename) max by (instance, nodename) (node_uname_info)",
          "legendFormat": "{{nodename}} {{mountpoint}}"
        }
      ],
      "title": "Filesystem Usage",
      "transparent": false,
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 66
      },
      "repeatDirection": "h",
      "options": {
        "displayMode": "gradient",
        "valueMode": "color",
        "namePlacement": "auto",
        "showUnfilled": true,
        "sizing": "auto",
        "minVizWidth": 8,
        "minVizHeight": 16,
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": false,
          "calcs": []
        },
        "reduceOptions": {
          "calcs": []
        },
        "maxVizHeight": 300,
        "orientation": "horizontal"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "targets": [
        {
          "expr": "(node_filesystem_size_bytes{instance=~\"$instance\",fstype=~\"ext[234]|xfs|btrfs|zfs|vfat\",mountpoint!~\"/var/lib/docker/.*\"} - node_filesystem_avail_bytes{instance=~\"$instance\",fstype=~\"ext[234]|xfs|btrfs|zfs|vfat\",mountpoint!~\"/var/lib/docker/.*\"}) * on(instance) group_left(nodename) max by (instance, nodename) (node_uname_info)",
          "legendFormat": "{{nodename}} {{mountpoint}} Used"
        },
        {
          "expr": "node_filesystem_size_bytes{instance=~\"$instance\",fstype=~\"ext[234]|xfs|btrfs|zfs|vfat\",mountpoint!~\"/var/lib/docker/.*\"} * on(instance) group_left(nodename) max by (instance, nodename) (node_uname_info)",
          "legendFormat": "{{nodename}} {{mountpoint}} Total"
        }
      ],
      "title": "Disk Space Used",
      "transparent": false,
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 66
      },
      "repeatDirection": "h",
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": false,
          "calcs": []
        },
        "tooltip": {
          "mode": "multi",
          "sort": ""
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        },
        "overrides": []
      }
    },
    {
      "type": "row",
      "collapsed": false,
      "title": "ZFS",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 74
      },
      "id": 0,
      "panels": []
    },
    {
      "type": "timeseries",
      "targets": [
        {
          "expr": "node_zfs_arc_size{instance=~\"$instance\"} * on(instance) group_left(nodename) max by (instance, nodename) (node_uname_info{nodename=\"pve\"})",
          "legendFormat": "{{nodename}} ARC Size",
          "refId": "A"
        },
        {
          "expr": "node_zfs_arc_c_max{instance=~\"$instance\"} * on(instance) group_left(nodename) max by (instance, nodename) (node_uname_info{nodename=\"pve\"})",
          "legendFormat": "{{nodename}} ARC Max",
          "refId": "B"
        },
        {
          "expr": "node_zfs_arc_c_min{instance=~\"$instance\"} * on(instance) group_left(nodename) max by (instance, nodename) (node_uname_info{nodename=\"pve\"})",
          "legendFormat": "{{nodename}} ARC Min",
          "refId": "C"
        },
        {
          "expr": "node_zfs_arc_size{instance=~\"$instance\"} * on(instance) group_left(nodename) max by (instance, nodename) (node_uname_info{nodename!=\"pve\"})",
          "legendFormat": "{{nodename}} ARC Size",
          "refId": "D"
        },
        {
          "expr": "node_zfs_arc_c_max{instance=~\"$instance\"} * on(instance) group_left(nodename) max by (instance, nodename) (node_uname_info{nodename!=\"pve\"})",
          "legendFormat": "{{nodename}} ARC Max",
          "refId": "E"
        },
        {
          "expr": "node_zfs_arc_c_min{instance=~\"$instance\"} * on(instance) group_left(nodename) max by (instance, nodename) (node_uname_info{nodename!=\"pve\"})",
          "legendFormat": "{{nodename}} ARC Min",
          "refId": "F"
        }
      ],
      "title": "ZFS ARC Size",
      "transparent": false,
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 75
      },
      "repeatDirection": "h",
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": false,
          "calcs": []
        },
        "tooltip": {
          "mode": "multi",
          "sort": ""
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        },
        "overrides": [
          {
            "matcher": {
              "id": "byFrameRefID",
              "options": "D"
            },
            "properties": [
              {
                "id": "custom.lineStyle",
                "value": {
                  "dash": [
                    8,
                    10
                  ],
                  "fill": "dash"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byFrameRefID",
              "options": "E"
            },
            "properties": [
              {
                "id": "custom.lineStyle",
                "value": {
                  "dash": [
                    8,
                    10
                  ],
                  "fill": "dash"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byFrameRefID",
              "options": "F"
            },
            "properties": [
              {
                "id": "custom.lineStyle",
                "value": {
                  "dash": [
                    8,
                    10
                  ],
                  "fill": "dash"
                }
              }
            ]
          }
        ]
      }
    }
  ],
  "templating": {
    "list": [
      {
        "type": "datasource",
        "name": "datasource",
