    {
      "type": "timeseries",
      "targets": [
        {
          "expr": "(1 - node_memory_MemAvailable_bytes{instance=~\"$instance\"} / node_memory_MemTotal_bytes{instance=~\"$instance\"}) * 100 * on(instance) group_left(nodename) max by (instance, nodename) (node_uname_info)",
          "legendFormat": "{{nodename}}"
        }
      ],
      "title": "Memory Usage",
