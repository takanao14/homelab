    {
      "type": "row",
      "collapsed": false,
      "title": "Temperature \u0026 Throttling",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 51
      },
      "id": 0,
      "panels": []
    },
    {
      "type": "timeseries",
      "targets": [
        {
          "expr": "((label_replace(node_thermal_zone_temp{type=~\"x86_pkg_temp|cpu-thermal\", instance=~\"$instance\"}, \"sensor\", \"$1\", \"type\", \"(.*)\")) or (label_replace(node_hwmon_temp_celsius{chip=~\".*_0000:00:18_.*\", sensor=\"temp1\", instance=~\"$instance\"}, \"sensor\", \"cpu\", \"\", \"\"))) * on(instance) group_left(nodename) max by (instance, nodename) (node_uname_info)",
          "legendFormat": "{{nodename}} CPU {{sensor}}"
        },
        {
          "expr": "(nvme_temperature_celsius{instance=~\"$instance\"}) * on(instance) group_left(nodename) max by (instance, nodename) (node_uname_info)",
          "legendFormat": "{{nodename}} NVMe {{device}}"
        },
        {
          "expr": "(smartmon_temperature_celsius_raw_value{instance=~\"$instance\"}) * on(instance) group_left(nodename) max by (instance, nodename) (node_uname_info)",
          "legendFormat": "{{nodename}} Disk {{device}}"
        }
      ],
      "title": "Temperature",
      "transparent": false,
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 52
      },
      "repeatDirection": "h",
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true,
