    {
      "type": "timeseries",
      "targets": [
        {
          "expr": "(node_memory_MemTotal_bytes{instance=~\"$instance\"} - node_memory_MemAvailable_bytes{instance=~\"$instance\"}) * on(instance) group_left(nodename) max by (instance, nodename) (node_uname_info)",
          "legendFormat": "{{nodename}}"
        }
      ],
      "title": "Memory Used",
      "transparent": false,
      "datasource": {
        "type": "prometheus",
