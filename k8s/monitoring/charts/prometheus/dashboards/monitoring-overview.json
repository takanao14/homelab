{
  "uid": "monitoring-overview",
  "title": "Monitoring Overview",
  "tags": [
    "monitoring",
    "infrastructure"
  ],
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "fiscalYearStartMonth": 0,
  "refresh": "30s",
  "schemaVersion": 42,
  "panels": [
    {
      "type": "stat",
      "targets": [
        {
          "expr": "count(up == 1)",
          "legendFormat": "Up"
        }
      ],
      "title": "Scrape Targets Up",
      "transparent": false,
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 0,
        "y": 0
      },
      "repeatDirection": "h",
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "targets": [
        {
          "expr": "count(up == 0) or vector(0)",
          "legendFormat": "Down"
        }
      ],
      "title": "Scrape Targets Down",
      "transparent": false,
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 4,
        "y": 0
      },
      "repeatDirection": "h",
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "green"
              },
              {
                "value": 1,
                "color": "red"
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "targets": [
        {
          "expr": "ceil(sum(increase(prometheus_notifications_dropped_total{cluster=~\"$cluster\",job=~\"$prometheus_job\"}[5m])))",
          "legendFormat": "Dropped"
        }
      ],
      "title": "Dropped Notifications (5m)",
      "transparent": false,
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 8,
        "y": 0
      },
      "repeatDirection": "h",
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "green"
              },
              {
                "value": 1,
                "color": "red"
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "targets": [
        {
          "expr": "sum(prometheus_tsdb_wal_corruptions_total{cluster=~\"$cluster\",job=~\"$prometheus_job\"}) or vector(0)",
          "legendFormat": "Corruptions"
        }
      ],
      "title": "WAL Corruptions",
      "transparent": false,
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 12,
        "y": 0
      },
      "repeatDirection": "h",
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "green"
              },
              {
                "value": 1,
                "color": "red"
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "targets": [
        {
          "expr": "sum(loki_ingester_memory_streams{job=\"loki\"})",
          "legendFormat": "Streams"
        }
      ],
      "title": "Loki Active Streams",
      "transparent": false,
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 16,
        "y": 0
      },
      "repeatDirection": "h",
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "targets": [
        {
          "expr": "sum(loki_ingester_chunk_utilization_sum{cluster=~\"$cluster\",job=~\"$loki_job\"}) / sum(loki_ingester_chunk_utilization_count{cluster=~\"$cluster\",job=~\"$loki_job\"})",
          "legendFormat": "Utilization"
        }
      ],
      "title": "Loki Chunk Utilization",
      "transparent": false,
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 20,
        "y": 0
      },
      "repeatDirection": "h",
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit"
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "targets": [
        {
          "expr": "rate(prometheus_tsdb_head_samples_appended_total{cluster=~\"$cluster\",job=~\"$prometheus_job\"}[5m])",
          "legendFormat": "samples/s"
        }
      ],
      "title": "Sample Ingestion Rate",
      "transparent": false,
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "repeatDirection": "h",
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "targets": [
        {
          "expr": "prometheus_tsdb_storage_blocks_bytes{cluster=~\"$cluster\",job=~\"$prometheus_job\"}",
          "legendFormat": "Blocks"
        },
        {
          "expr": "prometheus_tsdb_head_chunks{cluster=~\"$cluster\",job=~\"$prometheus_job\"} * 1024",
          "legendFormat": "Head (est.)"
        }
      ],
      "title": "TSDB Size",
      "transparent": false,
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 4
      },
      "repeatDirection": "h",
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (le, slice) (rate(prometheus_engine_query_duration_histogram_seconds_bucket{cluster=~\"$cluster\",job=~\"$prometheus_job\"}[5m])))",
          "legendFormat": "{{slice}}"
        }
      ],
      "title": "Query Duration p99",
      "transparent": false,
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 12
      },
      "repeatDirection": "h",
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      }
    },
    {
      "type": "bargauge",
      "targets": [
        {
          "expr": "sort_desc(topk(10, avg by (job) (scrape_duration_seconds)))",
          "legendFormat": "{{job}}"
        }
      ],
      "title": "Slowest Scrape Targets",
      "transparent": false,
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 12
      },
      "repeatDirection": "h",
      "options": {
        "displayMode": "gradient",
        "valueMode": "color",
        "namePlacement": "auto",
        "showUnfilled": true,
        "sizing": "auto",
        "minVizWidth": 8,
        "minVizHeight": 16,
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": false,
          "calcs": []
        },
        "reduceOptions": {
          "calcs": []
        },
        "maxVizHeight": 300,
        "orientation": "horizontal"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 3
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(loki_distributor_bytes_received_total{cluster=~\"$cluster\",job=~\"$loki_job\"}[5m]))",
          "legendFormat": "bytes/s"
        }
      ],
      "title": "Log Ingestion Rate",
      "transparent": false,
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 20
      },
      "repeatDirection": "h",
      "fieldConfig": {
        "defaults": {
          "unit": "Bps"
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(loki_distributor_lines_received_total{cluster=~\"$cluster\",job=~\"$loki_job\"}[5m]))",
          "legendFormat": "lines/s"
        }
      ],
      "title": "Log Lines Ingested Rate",
      "transparent": false,
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 20
      },
      "repeatDirection": "h",
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (le, route) (rate(loki_request_duration_seconds_bucket{cluster=~\"$cluster\",job=~\"$loki_job\"}[5m])))",
          "legendFormat": "{{route}}"
        }
      ],
      "title": "Loki Request Duration p99",
      "transparent": false,
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 28
      },
      "repeatDirection": "h",
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(loki_ingester_memory_streams{cluster=~\"$cluster\",job=~\"$loki_job\"})",
          "legendFormat": "Streams"
        }
      ],
      "title": "Loki Active Streams",
      "transparent": false,
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 28
      },
      "repeatDirection": "h",
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      }
    }
  ],
  "templating": {
    "list": [
      {
        "type": "datasource",
        "name": "datasource",
        "label": "Datasource",
        "skipUrlSync": false,
        "query": "prometheus",
        "multi": false,
        "allowCustomValue": true,
        "includeAll": false,
        "auto": false,
        "auto_min": "10s",
        "auto_count": 30
      },
      {
        "type": "query",
        "name": "cluster",
        "label": "Cluster",
        "skipUrlSync": false,
        "query": "label_values(kube_node_info, cluster)",
        "datasource": {
          "type": "prometheus",
          "uid": "$datasource"
        },
        "multi": true,
        "allowCustomValue": true,
        "refresh": 2,
        "sort": 1,
        "includeAll": true,
        "auto": false,
        "auto_min": "10s",
        "auto_count": 30
      },
      {
        "type": "query",
        "name": "prometheus_job",
        "label": "Prometheus Job",
        "skipUrlSync": false,
        "query": "label_values(prometheus_build_info{cluster=~\"$cluster\"}, job)",
        "datasource": {
          "type": "prometheus",
          "uid": "$datasource"
        },
        "multi": false,
        "allowCustomValue": true,
        "refresh": 2,
        "sort": 1,
        "includeAll": false,
        "auto": false,
        "auto_min": "10s",
        "auto_count": 30
      },
      {
        "type": "query",
        "name": "loki_job",
        "label": "Loki Job",
        "skipUrlSync": false,
        "query": "label_values(loki_build_info{cluster=~\"$cluster\"}, job)",
        "datasource": {
          "type": "prometheus",
          "uid": "$datasource"
        },
        "multi": false,
        "allowCustomValue": true,
        "refresh": 2,
        "sort": 1,
        "includeAll": false,
        "auto": false,
        "auto_min": "10s",
        "auto_count": 30
      }
    ]
  },
  "annotations": {}
}