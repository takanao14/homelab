        {
          "expr": "count by (node) (proxmox_vm_cpu_percent{job=\"proxmox-ve\", node=~\"$node\", type=\"qemu\"}) or on(node) count by (node) (proxmox_node_cpustat_cpu_percent{job=\"proxmox-ve\", node=~\"$node\"}) * 0",
