{
  "uid": "dns-overview",
  "title": "DNS Overview",
  "tags": [
    "dns",
    "infrastructure"
  ],
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "fiscalYearStartMonth": 0,
  "refresh": "30s",
  "schemaVersion": 42,
  "panels": [
    {
      "type": "row",
      "collapsed": false,
      "title": "dnsdist",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 0,
      "panels": []
    },
    {
      "type": "stat",
      "targets": [
        {
          "expr": "sum(rate(dnsdist_queries{job=\"scrapeConfig/monitoring/dnsdist-external\"}[5m]))",
          "legendFormat": "QPS"
        }
      ],
      "title": "dnsdist QPS",
      "transparent": false,
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 0,
        "y": 1
      },
      "repeatDirection": "h",
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "decimals": 1
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "targets": [
        {
          "expr": "sum(rate(dnsdist_cache_hits{job=\"scrapeConfig/monitoring/dnsdist-external\"}[5m])) / clamp_min(sum(rate(dnsdist_cache_hits{job=\"scrapeConfig/monitoring/dnsdist-external\"}[5m]) + rate(dnsdist_cache_misses{job=\"scrapeConfig/monitoring/dnsdist-external\"}[5m])), 1) * 100",
          "legendFormat": "Cache Hit Rate"
        }
      ],
      "title": "dnsdist Cache Hit Rate",
      "transparent": false,
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 8,
        "y": 1
      },
      "repeatDirection": "h",
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 2
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "targets": [
        {
          "expr": "avg(dnsdist_latency_avg100{job=\"scrapeConfig/monitoring/dnsdist-external\"})",
          "legendFormat": "Avg Latency"
        }
      ],
      "title": "dnsdist Avg Latency",
      "transparent": false,
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 16,
        "y": 1
      },
      "repeatDirection": "h",
      "options": {
        "graphMode": "area",
        "colorMode": "background",
        "justifyMode": "auto",
        "textMode": "auto",
        "wideLayout": true,
        "showPercentChange": false,
        "reduceOptions": {
          "calcs": []
        },
        "percentChangeColorMode": "standard",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "µs",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": 0,
                "color": "green"
              },
              {
                "value": 50000,
                "color": "yellow"
              },
              {
                "value": 150000,
                "color": "red"
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "type": "row",
