    {
      "type": "timeseries",
      "targets": [
        {
          "expr": "label_replace(label_replace(rate(dnsdist_queries{job=\"scrapeConfig/monitoring/dnsdist-external\"}[5m]), \"server\", \"ns1\", \"instance\", \"192.168.10.242:.*\"), \"server\", \"ns2\", \"instance\", \"192.168.10.241:.*\")",
          "legendFormat": "{{server}} Queries"
        },
        {
          "expr": "label_replace(label_replace(rate(dnsdist_responses{job=\"scrapeConfig/monitoring/dnsdist-external\"}[5m]), \"server\", \"ns1\", \"instance\", \"192.168.10.242:.*\"), \"server\", \"ns2\", \"instance\", \"192.168.10.241:.*\")",
