{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":separateMajorReleases",
    ":combinePatchMinorReleases",
    ":rebaseStalePrs"
  ],
  "timezone": "Asia/Tokyo",
  "schedule": ["at any time"],
  "minimumReleaseAge": "3 days",
  "labels": ["dependencies", "renovate"],
  "vulnerabilityAlerts": {
    "labels": ["security"],
    "assignees": ["takanao14"]
  },
  "packageRules": [
    {
      "description": "Apps & auxiliary components in k8s/ansible: auto-merge non-major updates. Renovate-native automerge (platformAutomerge=false) gates on lint without branch protection, so direct pushes to main stay unrestricted. OBSERVATION MODE: automerge stays false until classification is verified; flip to true to go live.",
      "matchFileNames": ["k8s/**", "ansible/**"],
      "matchUpdateTypes": ["minor", "patch", "pin", "digest"],
      "automerge": false,
      "automergeType": "pr",
      "platformAutomerge": false,
      "addLabels": ["auto-merge-candidate"]
    },
    {
      "description": "Cluster-foundation & stateful components: always review minor/major manually (ArgoCD auto-syncs to prod).",
      "matchPackageNames": [
        "/cilium/",
        "k0sproject/k0s",
        "openebs/openebs",
        "cert-manager",
        "argo-cd",
        "openbao/openbao",
        "seaweedfs/seaweedfs",
        "kube-prometheus-stack",
        "loki",
        "external-secrets"
      ],
      "matchUpdateTypes": ["minor", "major"],
      "automerge": false,
      "addLabels": ["infra-core", "manual-review"]
    },
    {
      "description": "GPU userspace driver (ROCm): review manually, tied to amdgpu-dkms.",
      "matchDatasources": ["custom.rocm"],
      "automerge": false,
      "addLabels": ["manual-review"]
    },
    {
      "description": "Never auto-merge major updates.",
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "addLabels": ["major-update"]
    },
    {
      "matchPackageNames": ["ghcr.io/gethomepage/homepage"],
      "groupName": "homepage updates"
    },
    {
      "matchDatasources": [
        "custom.rocm",
        "custom.amd-device-metrics-exporter"
      ],
      "extractVersion": "^(?<version>\\d+\\.\\d+(?:\\.\\d+)?)/$",
      "versioning": "semver-coerced"
    },
    {
      "matchDatasources": ["custom.amdgpu"],
      "allowedVersions": "/^30\\.30\\./",
      "extractVersion": "^(?<version>\\d+\\.\\d+(?:\\.\\d+)?)/$",
      "versioning": "semver-coerced",
      "automerge": false,
      "prBodyNotes": [
        "Update `rocm_udev_rules` to the matching package filename before merging.",
        "Validate the ROCm userspace update before explicitly upgrading `amdgpu-dkms`."
      ]
    }
  ],
  "customDatasources": {
    "rocm": {
      "defaultRegistryUrlTemplate": "https://repo.radeon.com/rocm/apt/",
      "format": "html"
    },
    "amdgpu": {
      "defaultRegistryUrlTemplate": "https://repo.radeon.com/amdgpu/",
      "format": "html"
    },
    "amd-device-metrics-exporter": {
      "defaultRegistryUrlTemplate": "https://repo.radeon.com/device-metrics-exporter/apt/",
      "format": "html"
    }
  },
  "helm-values": {
    "fileMatch": ["(^|/)values\\.yaml$"]
  },
  "kubernetes": {
    "fileMatch": ["(^|/)k8s/.+\\.yaml$"]
  },
  "helmfile": {
    "fileMatch": ["(^|/)k0s/helmfile\\.yaml\\.gotmpl$"]
  },
  "ansible-galaxy": {
    "fileMatch": ["(^|/)ansible/requirements\\.ya?ml$"]
  },
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": ["(^|/)ansible/.+\\.yaml$", "(^|/)ansible/.+\\.yml$"],
      "matchStrings": [
        "image:\\s*\"?(?<depName>[^\"]+):(?<currentValue>[^\"]+)\"?"
      ],
      "datasourceTemplate": "docker"
    },
    {
      "customType": "regex",
      "fileMatch": ["(^|/)k0s/env/.+\\.sh$"],
      "matchStrings": [
        "K0S_VERSION=(?<currentValue>[^\\s]+)"
      ],
      "depNameTemplate": "k0sproject/k0s",
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "loose"
    },
    {
      "customType": "regex",
      "fileMatch": ["(^|/)ansible/.+\\.ya?ml$"],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)(?: registryUrl=(?<registryUrl>\\S+))?\\n\\w+: \"(?<currentValue>[^\"]+)\""
      ]
    },
    {
      "customType": "regex",
      "fileMatch": ["(^|/)ansible/roles/forgejo_runner/defaults/main\\.ya?ml$"],
      "matchStrings": [
        "docker://(?<depName>catthehacker/ubuntu):(?<currentValue>[^\"]+)\""
      ],
      "datasourceTemplate": "docker"
    },
    {
      "customType": "regex",
      "fileMatch": ["(^|/)k8s/.+\\.yaml$"],
      "matchStrings": [
        "repoURL: (?<registryUrl>https://[^\\n]+)\\n\\s+chart: (?<depName>[^\\n]+)\\n\\s+targetRevision: (?<currentValue>[^\\n]+)"
      ],
      "datasourceTemplate": "helm"
    }
  ]
}
