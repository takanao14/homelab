{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":separateMajorReleases",
    ":combinePatchMinorReleases",
    ":rebaseStalePrs"
  ],
  "timezone": "Asia/Tokyo",
  "minimumReleaseAge": "1 day",
  "ignorePaths": [
    "**/node_modules/**",
    "**/bower_components/**",
    "**/vendor/**",
    "**/examples/**",
    "**/__tests__/**",
    "**/test/**",
    "**/tests/**",
    "**/__fixtures__/**",
    "**/templates/**"
  ],
  "labels": ["dependencies", "renovate"],
  "osvVulnerabilityAlerts": true,
  "vulnerabilityAlerts": {
    "labels": ["security"],
    "assignees": ["takanao14"],
    "minimumReleaseAge": null
  },
  "packageRules": [
    {
      "description": "Apps & auxiliary components in k8s/ansible/tf: auto-merge non-major updates. Renovate-native automerge (platformAutomerge=false) gates on lint without branch protection, so direct pushes to main stay unrestricted.",
      "matchFileNames": ["k8s/**", "ansible/**", "tf/**"],
      "matchUpdateTypes": ["minor", "patch", "pin", "digest"],
      "automerge": true,
      "automergeType": "pr",
      "platformAutomerge": false
    },
    {
      "description": "Terraform provider updates must refresh committed .terraform.lock.hcl files across all Terragrunt stacks.",
      "matchManagers": ["terraform"],
      "automerge": false,
      "addLabels": ["manual-review"]
    },
    {
      "description": "Cluster-foundation & stateful components on ArgoCD-synced paths: always review minor/major manually (merge = immediate deploy). openbao/seaweedfs are excluded because they live in ansible/ (manual apply, not deploy-on-merge).",
      "matchPackageNames": [
        "/cilium/",
        "k0sproject/k0s",
        "openebs/openebs",
        "cert-manager",
        "argo-cd",
        "kube-prometheus-stack",
        "loki",
        "external-secrets"
      ],
      "matchUpdateTypes": ["patch", "minor", "major"],
      "automerge": false,
      "addLabels": ["infra-core", "manual-review"]
    },
    {
      "description": "GPU userspace driver (ROCm): review manually, tied to amdgpu-dkms.",
      "matchDatasources": ["custom.rocm"],
      "automerge": false,
      "addLabels": ["manual-review"]
    },
    {
      "description": "These tools pin the CI lint/plan gates other automerges depend on; review manually so a breaking bump can't silently disable a gate.",
      "matchPackageNames": ["gruntwork-io/terragrunt", "ansible-lint", "hashicorp/packer"],
      "matchUpdateTypes": ["patch", "minor", "major"],
      "automerge": false,
      "addLabels": ["infra-core", "manual-review"]
    },
    {
      "description": "powerdns-webui is vendored into the pdns-ui chart. Renovate only bumps the ref in REVISION; the vendored bytes must be refreshed by sync.sh, and vendor-sync CI fails until they are.",
      "matchPackageNames": ["james-stevens/powerdns-webui"],
      "automerge": false,
      "addLabels": ["manual-review"],
      "prBodyNotes": [
        "Run `k8s/pdns-ui/chart/web/sync.sh` to refresh the vendored `index.html`, then re-verify the read-only behaviour documented in `k8s/pdns-ui/README.md`."
      ]
    },
    {
      "description": "Never auto-merge major updates.",
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "addLabels": ["major-update"]
    },
    {
      "description": "Internal Forgejo registry is LAN-only and unreachable from Mend cloud; do not track its images (e.g. comfyui-docker:latest).",
      "matchDatasources": ["docker"],
      "matchPackageNames": ["/^forgejo\\.home\\.butaco\\.net\\//"],
      "enabled": false
    },
    {
      "matchPackageNames": ["ghcr.io/gethomepage/homepage"],
      "groupName": "homepage updates"
    },
    {
      "matchDatasources": [
        "custom.rocm",
        "custom.amd-device-metrics-exporter"
      ],
      "extractVersion": "^(?<version>\\d+\\.\\d+(?:\\.\\d+)?)/$",
      "versioning": "semver-coerced"
    },
    {
      "matchDatasources": ["custom.amdgpu"],
      "allowedVersions": "/^30\\.30\\./",
      "extractVersion": "^(?<version>\\d+\\.\\d+(?:\\.\\d+)?)/$",
      "versioning": "semver-coerced",
      "automerge": false,
      "prBodyNotes": [
        "Update `rocm_udev_rules` to the matching package filename before merging.",
        "Validate the ROCm userspace update before explicitly upgrading `amdgpu-dkms`."
      ]
    }
  ],
  "customDatasources": {
    "rocm": {
      "defaultRegistryUrlTemplate": "https://repo.radeon.com/rocm/apt/",
      "format": "html"
    },
    "amdgpu": {
      "defaultRegistryUrlTemplate": "https://repo.radeon.com/amdgpu/",
      "format": "html"
    },
    "amd-device-metrics-exporter": {
      "defaultRegistryUrlTemplate": "https://repo.radeon.com/device-metrics-exporter/apt/",
      "format": "html"
    }
  },
  "helm-values": {
    "managerFilePatterns": [
      "/(^|/)values\\.yaml$/"
    ]
  },
  "kubernetes": {
    "managerFilePatterns": [
      "/(^|/)k8s/.+\\.yaml$/"
    ]
  },
  "helmfile": {
    "managerFilePatterns": [
      "/(^|/)k0s/helmfile\\.yaml\\.gotmpl$/"
    ]
  },
  "ansible-galaxy": {
    "managerFilePatterns": [
      "/(^|/)ansible/requirements\\.ya?ml$/"
    ]
  },
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/)ansible/.+\\.yaml$/",
        "/(^|/)ansible/.+\\.yml$/"
      ],
      "matchStrings": [
        "image:\\s*\"?(?<depName>[^\"]+):(?<currentValue>[^\"]+)\"?"
      ],
      "datasourceTemplate": "docker"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/)k0s/env/.+\\.sh$/"
      ],
      "matchStrings": [
        "K0S_VERSION=(?<currentValue>[^\\s]+)"
      ],
      "depNameTemplate": "k0sproject/k0s",
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "loose"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/)ansible/.+\\.ya?ml$/"
      ],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)(?: registryUrl=(?<registryUrl>\\S+))?\\n\\w+: \"(?<currentValue>[^\"]+)\""
      ]
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/)k8s/pdns-ui/chart/web/REVISION$/"
      ],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)\\nref: (?<currentValue>\\S+)"
      ],
      "versioningTemplate": "loose"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/)\\.github/workflows/.+\\.ya?ml$/"
      ],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)\\n\\s*\\w+: \"(?<currentValue>[^\"]+)\""
      ]
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/)packer/.+\\.pkr\\.hcl$/"
      ],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)\\n\\s*version\\s*=\\s*\"(?<currentValue>[^\"]+)\""
      ]
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/)ansible/roles/forgejo_runner/defaults/main\\.ya?ml$/"
      ],
      "matchStrings": [
        "docker://(?<depName>catthehacker/ubuntu):(?<currentValue>[^\"]+)\""
      ],
      "datasourceTemplate": "docker"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/)k8s/.+\\.yaml$/"
      ],
      "matchStrings": [
        "repoURL: (?<registryUrl>https://[^\\n]+)\\n\\s+chart: (?<depName>[^\\n]+)\\n\\s+targetRevision: (?<currentValue>[^\\n]+)"
      ],
      "datasourceTemplate": "helm"
    }
  ]
}
