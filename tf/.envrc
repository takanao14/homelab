source_up

# Shared remote-state backend credentials for every Terragrunt module.
# Injects the Cloudflare R2 (S3-compatible) access key, secret, and endpoint
# consumed by the s3 backend in tf/root.hcl. Picked up by each module's .envrc
# through `source_up`. Plaintext secrets are never committed; they live in the
# SOPS-encrypted file decrypted below. `git rev-parse` keeps the path correct
# regardless of which module directory direnv loads from.
set -a
source <(sops --decrypt "$(git rev-parse --show-toplevel)/tf/.env/secrets.common.enc.env")
set +a
