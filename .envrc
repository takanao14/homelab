# Grafana MCP server credentials, consumed by scripts/grafana-mcp.sh via .mcp.json.
# GRAFANA_URL is non-secret and inlined; the service account token lives in the
# SOPS-encrypted file decrypted below. Plaintext secrets are never committed.
export GRAFANA_URL="https://grafana.prd.butaco.net"

# Guard so directories that `source_up` into this file don't break before the
# encrypted secret exists (e.g. fresh clone without the age key yet).
grafana_secret_file="$(git rev-parse --show-toplevel)/.env/secrets.enc.env"
if [ -f "${grafana_secret_file}" ]; then
  set -a
  source <(sops --decrypt "${grafana_secret_file}")
  set +a
fi
unset grafana_secret_file
